      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  body {\n    font-family: 'Inter', sans-serif;\n    background-color: #f9fafb;\n    margin: 0;\n    padding: 40px;\n    display: flex;\n    justify-content: center;\n    align-items: center;\n    min-height: 100vh;\n  }\n</style>\n\n<div class=\"w-full max-w-[1000px] bg-white rounded-xl border border-gray-200 shadow-sm overflow-hidden\" data-kid=\"1\">\n  \n  <div class=\"flex items-center justify-between px-8 py-5 border-b border-gray-100\" data-kid=\"2\">\n    <h2 class=\"text-[13px] font-bold text-[#64748b] tracking-wider\" data-kid=\"3\">CREATE NEW ENTRY</h2>\n    <button class=\"text-gray-400 hover:text-gray-600 transition-colors\" data-kid=\"4\">\n      <i class=\"ti ti-x text-xl\" data-kid=\"5\"></i>\n    </button>\n  </div>\n\n  \n  <div class=\"p-8\" data-kid=\"6\">\n    <div class=\"grid grid-cols-12 gap-10\" data-kid=\"7\">\n      \n      <div class=\"col-span-7 space-y-6\" data-kid=\"8\">\n        <div class=\"grid grid-cols-2 gap-6\" data-kid=\"9\">\n          \n          <div class=\"flex flex-col gap-1.5\" data-kid=\"10\">\n            <label class=\"text-[11px] font-bold text-[#94a3b8] tracking-wide uppercase\" data-kid=\"11\">\n              AWARD TITLE <span class=\"text-red-500\" data-kid=\"12\">*</span>\n            </label>\n            <input type=\"text\" placeholder=\"e.g. Humanitarian Excellence 2024\" class=\"w-full px-4 py-3 bg-[#f8fafc] border border-[#e2e8f0] rounded-lg text-sm text-[#334155] placeholder-[#94a3b8] focus:outline-hidden focus:ring-2 focus:ring-[#2d6fa3]/10 focus:border-[#2d6fa3] transition-all\" data-kid=\"13\">\n          </div>\n          \n          <div class=\"flex flex-col gap-1.5\" data-kid=\"14\">\n            <label class=\"text-[11px] font-bold text-[#94a3b8] tracking-wide uppercase\" data-kid=\"15\">\n              ORGANIZATION <span class=\"text-red-500\" data-kid=\"16\">*</span>\n            </label>\n            <input type=\"text\" placeholder=\"e.g. UNESCO\" class=\"w-full px-4 py-3 bg-[#f8fafc] border border-[#e2e8f0] rounded-lg text-sm text-[#334155] placeholder-[#94a3b8] focus:outline-hidden focus:ring-2 focus:ring-[#2d6fa3]/10 focus:border-[#2d6fa3] transition-all\" data-kid=\"17\">\n          </div>\n        </div>\n\n        <div class=\"grid grid-cols-2 gap-6\" data-kid=\"18\">\n          \n          <div class=\"flex flex-col gap-1.5\" data-kid=\"19\">\n            <label class=\"text-[11px] font-bold text-[#94a3b8] tracking-wide uppercase\" data-kid=\"20\">RECIPIENT</label>\n            <input type=\"text\" placeholder=\"Person name (if specific)\" class=\"w-full px-4 py-3 bg-[#f8fafc] border border-[#e2e8f0] rounded-lg text-sm text-[#334155] placeholder-[#94a3b8] focus:outline-hidden focus:ring-2 focus:ring-[#2d6fa3]/10 focus:border-[#2d6fa3] transition-all\" data-kid=\"21\">\n          </div>\n          \n          <div class=\"flex flex-col gap-1.5\" data-kid=\"22\">\n            <label class=\"text-[11px] font-bold text-[#94a3b8] tracking-wide uppercase\" data-kid=\"23\">LINK TYPE</label>\n            <div class=\"relative\" data-kid=\"24\">\n              <select class=\"w-full px-4 py-3 bg-[#f8fafc] border border-[#e2e8f0] rounded-lg text-sm text-[#334155] appearance-none focus:outline-hidden focus:ring-2 focus:ring-[#2d6fa3]/10 focus:border-[#2d6fa3] transition-all\" data-kid=\"25\">\n                <option data-kid=\"26\">None</option>\n                <option data-kid=\"27\">Website</option>\n                <option data-kid=\"28\">Article</option>\n                <option data-kid=\"29\">Video</option>\n              </select>\n              <div class=\"absolute inset-y-0 right-4 flex items-center pointer-events-none text-[#94a3b8]\" data-kid=\"30\">\n                <i class=\"ti ti-chevron-down text-base\" data-kid=\"31\"></i>\n              </div>\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"flex flex-col gap-1.5\" data-kid=\"32\">\n          <label class=\"text-[11px] font-bold text-[#94a3b8] tracking-wide uppercase\" data-kid=\"33\">SUMMARY DESCRIPTION</label>\n          <textarea rows=\"4\" placeholder=\"Briefly describe the significance of this award...\" class=\"w-full px-4 py-3 bg-[#f8fafc] border border-[#e2e8f0] rounded-lg text-sm text-[#334155] placeholder-[#94a3b8] resize-none focus:outline-hidden focus:ring-2 focus:ring-[#2d6fa3]/10 focus:border-[#2d6fa3] transition-all\" data-kid=\"34\"></textarea>\n        </div>\n      </div>\n\n      \n      <div class=\"col-span-5 flex flex-col gap-1.5\" data-kid=\"35\">\n        <label class=\"text-[11px] font-bold text-[#94a3b8] tracking-wide uppercase\" data-kid=\"36\">FEATURED MEDIA</label>\n        <div class=\"flex-1 min-h-[260px] border-2 border-dashed border-[#e2e8f0] rounded-xl bg-[#f8fafc] hover:bg-[#f1f5f9] hover:border-[#cbd5e1] transition-all cursor-pointer flex flex-col items-center justify-center p-8 text-center group\" data-kid=\"37\">\n          <div class=\"w-12 h-12 rounded-full bg-white border border-[#e2e8f0] flex items-center justify-center mb-4 text-[#2d6fa3] shadow-xs group-hover:scale-110 transition-transform\" data-kid=\"38\">\n            <i class=\"ti ti-upload text-xl\" data-kid=\"39\"></i>\n          </div>\n          <p class=\"text-[14px] font-semibold text-[#475569] mb-1\" data-kid=\"40\">Drop your file here</p>\n          <p class=\"text-[11px] font-medium text-[#94a3b8] uppercase tracking-wide\" data-kid=\"41\">JPG, PNG OR WEBP UP TO 2MB</p>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"px-8 py-6 bg-white border-t border-gray-100 flex items-center justify-end gap-6\" data-kid=\"42\">\n    <button class=\"text-sm font-semibold text-[#64748b] hover:text-[#334155] transition-colors\" data-kid=\"43\">Discard</button>\n    <button class=\"bg-[#2d6fa3] hover:bg-[#245a85] text-white px-6 py-3 rounded-lg text-sm font-semibold shadow-xs hover:shadow-md transform active:scale-95 transition-all\" data-kid=\"44\">\n      Publish Award Entry\n    </button>\n  </div>\n</div>",
