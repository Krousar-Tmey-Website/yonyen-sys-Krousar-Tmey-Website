    "var_f1840945fba0": {
      "type": "variant",
      "label": "Admin: Editorial Chic",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 0,
        "y": 0,
        "w": 1440,
        "h": 800
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:ital,wght@0,700;1,700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  .font-serif { font-family: 'Playfair Display', serif; }\n  .font-sans { font-family: 'Inter', sans-serif; }\n\n  /* Custom scrollbar for data density */\n  .custom-scrollbar::-webkit-scrollbar {\n    width: 6px;\n  }\n  .custom-scrollbar::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  .custom-scrollbar::-webkit-scrollbar-thumb {\n    background: #e2e8f0;\n    border-radius: 10px;\n  }\n  .custom-scrollbar::-webkit-scrollbar-thumb:hover {\n    background: #cbd5e1;\n  }\n</style>\n\n<div class=\"min-h-screen bg-[#fafbfc] font-sans text-[#1e293b] p-8\" data-kid=\"1\">\n  <div class=\"max-w-[1300px] mx-auto\" data-kid=\"2\">\n    \n    \n    <header class=\"flex flex-col md:flex-row md:items-center justify-between gap-6 mb-10 border-b border-gray-200 pb-8\" data-kid=\"3\">\n      <div class=\"space-y-2\" data-kid=\"4\">\n        <nav class=\"flex items-center gap-2 text-[11px] font-semibold uppercase tracking-widest text-gray-400\" data-kid=\"5\">\n          <a href=\"#\" class=\"hover:text-[#2d6fa3] transition-colors\" data-kid=\"6\">Dashboard</a>\n          <i class=\"ti ti-chevron-right text-[10px]\" data-kid=\"7\"></i>\n          <span class=\"text-gray-600\" data-kid=\"8\">Awards Management</span>\n        </nav>\n        <div class=\"flex items-center gap-4\" data-kid=\"9\">\n          <h1 class=\"text-3xl font-serif text-[#1e293b]\" data-kid=\"10\">Awards & Honors</h1>\n          <div class=\"flex items-center gap-2\" data-kid=\"11\">\n            <span class=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-gray-100 text-gray-600 border border-gray-200\" data-kid=\"12\">\n              <i class=\"ti ti-award mr-1 text-[14px]\" data-kid=\"13\"></i> 24 Total\n            </span>\n            <span class=\"inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-blue-50 text-[#2d6fa3] border border-blue-100\" data-kid=\"14\">\n              <i class=\"ti ti-photo mr-1 text-[14px]\" data-kid=\"15\"></i> 18 Images\n            </span>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"flex items-center gap-3\" data-kid=\"16\">\n        <button class=\"inline-flex items-center gap-2 px-5 py-2.5 bg-[#1e293b] text-white rounded-lg text-sm font-semibold hover:bg-black transition-all shadow-sm\" data-kid=\"17\">\n          <i class=\"ti ti-plus text-[16px]\" data-kid=\"18\"></i>\n          Add New Award\n        </button>\n      </div>\n    </header>\n\n    \n    <section class=\"bg-white border border-gray-200 rounded-2xl shadow-sm mb-10 overflow-hidden transition-all duration-300\" data-kid=\"19\">\n      <div class=\"px-8 py-4 bg-gray-50/50 border-b border-gray-100 flex items-center justify-between\" data-kid=\"20\">\n        <h3 class=\"text-sm font-bold uppercase tracking-wider text-gray-500\" data-kid=\"21\">Create New Entry</h3>\n        <button class=\"text-gray-400 hover:text-gray-600\" data-kid=\"22\">\n          <i class=\"ti ti-x text-xl\" data-kid=\"23\"></i>\n        </button>\n      </div>\n      <div class=\"p-8\" data-kid=\"24\">\n        <form class=\"grid grid-cols-1 lg:grid-cols-12 gap-8\" data-kid=\"25\">\n          \n          <div class=\"lg:col-span-8 grid grid-cols-1 md:grid-cols-2 gap-6\" data-kid=\"26\">\n            <div class=\"space-y-1.5\" data-kid=\"27\">\n              <label class=\"text-[11px] font-bold uppercase tracking-wider text-gray-400\" data-kid=\"28\">Award Title <span class=\"text-red-500\" data-kid=\"29\">*</span></label>\n              <input type=\"text\" placeholder=\"e.g. Humanitarian Excellence 2024\" class=\"w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-[#2d6fa3]/10 focus:border-[#2d6fa3] outline-hidden transition-all text-sm\" data-kid=\"30\">\n            </div>\n            <div class=\"space-y-1.5\" data-kid=\"31\">\n              <label class=\"text-[11px] font-bold uppercase tracking-wider text-gray-400\" data-kid=\"32\">Organization <span class=\"text-red-500\" data-kid=\"33\">*</span></label>\n              <input type=\"text\" placeholder=\"e.g. UNESCO\" class=\"w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-[#2d6fa3]/10 focus:border-[#2d6fa3] outline-hidden transition-all text-sm\" data-kid=\"34\">\n            </div>\n            <div class=\"space-y-1.5\" data-kid=\"35\">\n              <label class=\"text-[11px] font-bold uppercase tracking-wider text-gray-400\" data-kid=\"36\">Recipient</label>\n              <input type=\"text\" placeholder=\"Person name (if specific)\" class=\"w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-[#2d6fa3]/10 focus:border-[#2d6fa3] outline-hidden transition-all text-sm\" data-kid=\"37\">\n            </div>\n            <div class=\"space-y-1.5\" data-kid=\"38\">\n              <label class=\"text-[11px] font-bold uppercase tracking-wider text-gray-400\" data-kid=\"39\">Link Type</label>\n              <select class=\"w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-[#2d6fa3]/10 focus:border-[#2d6fa3] outline-hidden transition-all text-sm appearance-none\" data-kid=\"40\">\n                <option data-kid=\"41\">None</option>\n                <option data-kid=\"42\">Visit Website</option>\n                <option data-kid=\"43\">Read Article</option>\n                <option data-kid=\"44\">Watch Video</option>\n              </select>\n            </div>\n            <div class=\"md:col-span-2 space-y-1.5\" data-kid=\"45\">\n              <label class=\"text-[11px] font-bold uppercase tracking-wider text-gray-400\" data-kid=\"46\">Summary Description</label>\n              <textarea rows=\"3\" placeholder=\"Briefly describe the significance of this award...\" class=\"w-full px-4 py-3 bg-gray-50 border border-gray-200 rounded-xl focus:ring-2 focus:ring-[#2d6fa3]/10 focus:border-[#2d6fa3] outline-hidden transition-all text-sm resize-none\" data-kid=\"47\"></textarea>\n            </div>\n          </div>\n\n          \n          <div class=\"lg:col-span-4 space-y-4\" data-kid=\"48\">\n            <label class=\"text-[11px] font-bold uppercase tracking-wider text-gray-400\" data-kid=\"49\">Featured Media</label>\n            <div class=\"group relative border-2 border-dashed border-gray-200 rounded-2xl p-8 text-center hover:border-[#2d6fa3]/50 transition-colors bg-gray-50/50 cursor-pointer h-[calc(100%-1.5rem)] flex flex-col items-center justify-center\" data-kid=\"50\">\n              <div class=\"w-12 h-12 bg-white rounded-full flex items-center justify-center shadow-sm mb-4 group-hover:scale-110 transition-transform\" data-kid=\"51\">\n                <i class=\"ti ti-upload text-[#2d6fa3] text-xl\" data-kid=\"52\"></i>\n              </div>\n              <p class=\"text-sm font-semibold text-gray-700\" data-kid=\"53\">Drop your file here</p>\n              <p class=\"text-[11px] text-gray-400 mt-1 uppercase tracking-tighter\" data-kid=\"54\">JPG, PNG or WebP up to 2MB</p>\n            </div>\n          </div>\n        </form>\n        <div class=\"mt-8 pt-8 border-t border-gray-100 flex justify-end gap-3\" data-kid=\"55\">\n          <button class=\"px-6 py-2.5 text-sm font-semibold text-gray-500 hover:text-gray-700 transition-colors\" data-kid=\"56\">Discard</button>\n          <button class=\"px-8 py-2.5 bg-[#2d6fa3] text-white rounded-lg text-sm font-semibold hover:bg-[#1a3c6e] transition-all shadow-md\" data-kid=\"57\">Publish Award Entry</button>\n        </div>\n      </div>\n    </section>\n\n    \n    <main class=\"bg-white border border-gray-200 rounded-2xl shadow-sm overflow-hidden\" data-kid=\"58\">\n      <div class=\"px-8 py-5 border-b border-gray-100 flex items-center justify-between\" data-kid=\"59\">\n        <h2 class=\"text-lg font-serif\" data-kid=\"60\">Recent Records</h2>\n        <div class=\"relative w-64\" data-kid=\"61\">\n          <i class=\"ti ti-search absolute left-3 top-1/2 -translate-y-1/2 text-gray-400\" data-kid=\"62\"></i>\n          <input type=\"text\" placeholder=\"Search records...\" class=\"w-full pl-10 pr-4 py-2 bg-gray-50 border border-gray-200 rounded-lg text-xs outline-hidden focus:ring-1 focus:ring-[#2d6fa3]\" data-kid=\"63\">\n        </div>\n      </div>\n      \n      <div class=\"overflow-x-auto custom-scrollbar\" data-kid=\"64\">\n        <table class=\"w-full text-left border-collapse\" data-kid=\"65\">\n          <thead data-kid=\"66\">\n            <tr class=\"bg-gray-50/50\" data-kid=\"67\">\n              <th class=\"px-8 py-4 text-[11px] font-bold uppercase tracking-widest text-gray-400 border-b border-gray-100\" data-kid=\"68\">Media</th>\n              <th class=\"px-8 py-4 text-[11px] font-bold uppercase tracking-widest text-gray-400 border-b border-gray-100\" data-kid=\"69\">Award Details</th>\n              <th class=\"px-8 py-4 text-[11px] font-bold uppercase tracking-widest text-gray-400 border-b border-gray-100\" data-kid=\"70\">Narrative</th>\n              <th class=\"px-8 py-4 text-[11px] font-bold uppercase tracking-widest text-gray-400 border-b border-gray-100\" data-kid=\"71\">Status</th>\n              <th class=\"px-8 py-4 text-[11px] font-bold uppercase tracking-widest text-gray-400 border-b border-gray-100 text-right\" data-kid=\"72\">Actions</th>\n            </tr>\n          </thead>\n          <tbody class=\"divide-y divide-gray-50\" data-kid=\"73\">\n            \n            <tr class=\"hover:bg-gray-50/50 transition-colors group\" data-kid=\"74\">\n              <td class=\"px-8 py-6\" data-kid=\"75\">\n                <div class=\"w-14 h-14 rounded-xl overflow-hidden shadow-sm ring-1 ring-gray-100\" data-kid=\"76\">\n                  <img src=\"https://images.unsplash.com/photo-1593113598332-cd288d649433?auto=format&w=120&q=80&fit=crop\" alt=\"Joel Muniz on Unsplash\" class=\"w-full h-full object-cover\" data-kid=\"77\">\n                </div>\n              </td>\n              <td class=\"px-8 py-6\" data-kid=\"78\">\n                <div class=\"space-y-0.5\" data-kid=\"79\">\n                  <div class=\"text-sm font-bold text-gray-800\" data-kid=\"80\">Humanitarian Excellence Award</div>\n                  <div class=\"text-[11px] font-semibold text-[#2d6fa3] uppercase tracking-wider\" data-kid=\"81\">UNESCO International</div>\n                  <div class=\"text-[10px] text-gray-400 italic\" data-kid=\"82\">Recipient: Benito Juarez</div>\n                </div>\n              </td>\n              <td class=\"px-8 py-6 max-w-xs\" data-kid=\"83\">\n                <p class=\"text-xs text-gray-500 leading-relaxed line-clamp-2\" data-kid=\"84\">Recognized for outstanding contribution to inclusive education and vocational training for vulnerable children in Southeast Asia.</p>\n              </td>\n              <td class=\"px-8 py-6\" data-kid=\"85\">\n                <span class=\"inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase bg-green-50 text-green-600 border border-green-100\" data-kid=\"86\">\n                  <i class=\"ti ti-world text-[12px]\" data-kid=\"87\"></i> Website\n                </span>\n              </td>\n              <td class=\"px-8 py-6 text-right\" data-kid=\"88\">\n                <div class=\"flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"89\">\n                  <button class=\"p-2 text-gray-400 hover:text-[#2d6fa3] hover:bg-blue-50 rounded-lg transition-all\" title=\"Edit Entry\" data-kid=\"90\">\n                    <i class=\"ti ti-edit text-lg\" data-kid=\"91\"></i>\n                  </button>\n                  <button class=\"p-2 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all\" title=\"Delete Entry\" data-kid=\"92\">\n                    <i class=\"ti ti-trash text-lg\" data-kid=\"93\"></i>\n                  </button>\n                </div>\n              </td>\n            </tr>\n\n            \n            <tr class=\"hover:bg-gray-50/50 transition-colors group\" data-kid=\"94\">\n              <td class=\"px-8 py-6\" data-kid=\"95\">\n                <div class=\"w-14 h-14 rounded-xl bg-gradient-to-br from-[#1e293b] to-[#2d6fa3] flex items-center justify-center shadow-sm\" data-kid=\"96\">\n                  <i class=\"ti ti-medal text-white text-2xl\" data-kid=\"97\"></i>\n                </div>\n              </td>\n              <td class=\"px-8 py-6\" data-kid=\"98\">\n                <div class=\"space-y-0.5\" data-kid=\"99\">\n                  <div class=\"text-sm font-bold text-gray-800\" data-kid=\"100\">Child Welfare Global Prize</div>\n                  <div class=\"text-[11px] font-semibold text-[#2d6fa3] uppercase tracking-wider\" data-kid=\"101\">UNICEF Foundation</div>\n                </div>\n              </td>\n              <td class=\"px-8 py-6 max-w-xs\" data-kid=\"102\">\n                <p class=\"text-xs text-gray-500 leading-relaxed line-clamp-2\" data-kid=\"103\">A prestigious award honoring three decades of commitment to deaf and blind education in Cambodia's rural provinces.</p>\n              </td>\n              <td class=\"px-8 py-6\" data-kid=\"104\">\n                <span class=\"inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase bg-orange-50 text-orange-600 border border-orange-100\" data-kid=\"105\">\n                  <i class=\"ti ti-news text-[12px]\" data-kid=\"106\"></i> Article\n                </span>\n              </td>\n              <td class=\"px-8 py-6 text-right\" data-kid=\"107\">\n                <div class=\"flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"108\">\n                  <button class=\"p-2 text-gray-400 hover:text-[#2d6fa3] hover:bg-blue-50 rounded-lg transition-all\" data-kid=\"109\">\n                    <i class=\"ti ti-edit text-lg\" data-kid=\"110\"></i>\n                  </button>\n                  <button class=\"p-2 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all\" data-kid=\"111\">\n                    <i class=\"ti ti-trash text-lg\" data-kid=\"112\"></i>\n                  </button>\n                </div>\n              </td>\n            </tr>\n\n            \n            <tr class=\"hover:bg-gray-50/50 transition-colors group\" data-kid=\"113\">\n              <td class=\"px-8 py-6\" data-kid=\"114\">\n                <div class=\"w-14 h-14 rounded-xl overflow-hidden shadow-sm ring-1 ring-gray-100\" data-kid=\"115\">\n                  <img src=\"https://images.unsplash.com/photo-1544928938-6852c1925194?auto=format&w=120&q=80&fit=crop\" alt=\"victoria gonzales on Unsplash\" class=\"w-full h-full object-cover\" data-kid=\"116\">\n                </div>\n              </td>\n              <td class=\"px-8 py-6\" data-kid=\"117\">\n                <div class=\"space-y-0.5\" data-kid=\"118\">\n                  <div class=\"text-sm font-bold text-gray-800\" data-kid=\"119\">Social Innovation Grant</div>\n                  <div class=\"text-[11px] font-semibold text-[#2d6fa3] uppercase tracking-wider\" data-kid=\"120\">Google for NGOs</div>\n                </div>\n              </td>\n              <td class=\"px-8 py-6 max-w-xs\" data-kid=\"121\">\n                <p class=\"text-xs text-gray-500 leading-relaxed line-clamp-2\" data-kid=\"122\">Special recognition for the 'Digital Inclusion' program, providing accessible technology to students with disabilities.</p>\n              </td>\n              <td class=\"px-8 py-6\" data-kid=\"123\">\n                <span class=\"inline-flex items-center gap-1.5 px-2.5 py-1 rounded-full text-[10px] font-bold uppercase bg-purple-50 text-purple-600 border border-purple-100\" data-kid=\"124\">\n                  <i class=\"ti ti-player-play text-[12px]\" data-kid=\"125\"></i> Video\n                </span>\n              </td>\n              <td class=\"px-8 py-6 text-right\" data-kid=\"126\">\n                <div class=\"flex items-center justify-end gap-2 opacity-0 group-hover:opacity-100 transition-opacity\" data-kid=\"127\">\n                  <button class=\"p-2 text-gray-400 hover:text-[#2d6fa3] hover:bg-blue-50 rounded-lg transition-all\" data-kid=\"128\">\n                    <i class=\"ti ti-edit text-lg\" data-kid=\"129\"></i>\n                  </button>\n                  <button class=\"p-2 text-gray-400 hover:text-red-600 hover:bg-red-50 rounded-lg transition-all\" data-kid=\"130\">\n                    <i class=\"ti ti-trash text-lg\" data-kid=\"131\"></i>\n                  </button>\n                </div>\n              </td>\n            </tr>\n          </tbody>\n        </table>\n      </div>\n\n      \n      <footer class=\"px-8 py-4 bg-gray-50/50 border-t border-gray-100 flex items-center justify-between\" data-kid=\"132\">\n        <p class=\"text-[11px] font-semibold text-gray-400 uppercase tracking-widest\" data-kid=\"133\">Showing 1 to 10 of 24 records</p>\n        <div class=\"flex items-center gap-1\" data-kid=\"134\">\n          <button class=\"p-2 text-gray-400 hover:text-gray-600 disabled:opacity-30\" disabled data-kid=\"135\">\n            <i class=\"ti ti-chevron-left text-lg\" data-kid=\"136\"></i>\n          </button>\n          <button class=\"w-8 h-8 rounded-lg bg-[#2d6fa3] text-white text-[11px] font-bold\" data-kid=\"137\">1</button>\n          <button class=\"w-8 h-8 rounded-lg text-gray-400 hover:bg-gray-100 text-[11px] font-bold transition-colors\" data-kid=\"138\">2</button>\n          <button class=\"w-8 h-8 rounded-lg text-gray-400 hover:bg-gray-100 text-[11px] font-bold transition-colors\" data-kid=\"139\">3</button>\n          <button class=\"p-2 text-gray-400 hover:text-gray-600\" data-kid=\"140\">\n            <i class=\"ti ti-chevron-right text-lg\" data-kid=\"141\"></i>\n          </button>\n        </div>\n      </footer>\n    </main>\n\n  </div>\n</div>",
