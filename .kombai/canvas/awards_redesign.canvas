        "h": 800
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  .font-sans { font-family: 'Inter', sans-serif; }\n  .font-serif { font-family: 'Playfair Display', serif; }\n</style>\n\n<div class=\"min-h-screen bg-[#f8f9fa] font-sans text-[#1e293b] p-8\" data-kid=\"1\">\n  \n  <header class=\"mb-10\" data-kid=\"2\">\n    <div class=\"flex flex-col md:flex-row md:items-center justify-between gap-4 mb-8\" data-kid=\"3\">\n      <div data-kid=\"4\">\n        <nav class=\"flex items-center gap-2 text-xs text-gray-400 mb-2 uppercase tracking-widest font-bold\" data-kid=\"5\">\n          <a href=\"#\" class=\"hover:text-[#2d6fa3] transition-colors\" data-kid=\"6\">Dashboard</a>\n          <i class=\"ti ti-chevron-right text-[10px]\" data-kid=\"7\"></i>\n          <span class=\"text-[#2d6fa3]\" data-kid=\"8\">Awards Management</span>\n        </nav>\n        <h1 class=\"text-3xl font-serif text-[#1d4e7a]\" data-kid=\"9\">Awards & Recognitions</h1>\n      </div>\n      <div class=\"flex items-center gap-3\" data-kid=\"10\">\n        <button class=\"flex items-center gap-2 bg-white border border-gray-200 text-gray-600 px-4 py-2 rounded-xl text-sm font-medium hover:bg-gray-50 transition-all\" data-kid=\"11\">\n          <i class=\"ti ti-download\" data-kid=\"12\"></i> Export Report\n        </button>\n        <button class=\"flex items-center gap-2 bg-[#2d6fa3] text-white px-5 py-2.5 rounded-xl text-sm font-semibold shadow-lg shadow-[#2d6fa3]/20 hover:bg-[#1d4e7a] transition-all\" data-kid=\"13\">\n          <i class=\"ti ti-plus\" data-kid=\"14\"></i> View Public Page\n        </button>\n      </div>\n    </div>\n\n    \n    <div class=\"grid grid-cols-1 md:grid-cols-3 gap-6\" data-kid=\"15\">\n      \n      <div class=\"relative overflow-hidden bg-white rounded-2xl border border-gray-100 p-6 shadow-sm group\" data-kid=\"16\">\n        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/viscious-speed/abstract-118.svg\" class=\"absolute -top-4 -right-4 w-24 h-24 opacity-5 group-hover:opacity-10 transition-opacity\" style=\"filter: invert(34%) sepia(85%) saturate(415%) hue-rotate(165deg) brightness(92%) contrast(88%);\" data-kid=\"17\">\n        <div class=\"relative z-10 flex items-center gap-4\" data-kid=\"18\">\n          <div class=\"w-14 h-14 rounded-2xl bg-[#2d6fa3]/10 flex items-center justify-center text-[#2d6fa3]\" data-kid=\"19\">\n            <i class=\"ti ti-award text-2xl\" data-kid=\"20\"></i>\n          </div>\n          <div data-kid=\"21\">\n            <p class=\"text-sm text-gray-400 font-medium\" data-kid=\"22\">Total Awards</p>\n            <p class=\"text-3xl font-bold text-[#1d4e7a]\" data-kid=\"23\">24</p>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"relative overflow-hidden bg-white rounded-2xl border border-gray-100 p-6 shadow-sm group\" data-kid=\"24\">\n        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/viscious-speed/abstract-011.svg\" class=\"absolute -top-4 -right-4 w-24 h-24 opacity-5 group-hover:opacity-10 transition-opacity\" style=\"filter: invert(34%) sepia(85%) saturate(415%) hue-rotate(165deg) brightness(92%) contrast(88%);\" data-kid=\"25\">\n        <div class=\"relative z-10 flex items-center gap-4\" data-kid=\"26\">\n          <div class=\"w-14 h-14 rounded-2xl bg-[#8da83a]/10 flex items-center justify-center text-[#8da83a]\" data-kid=\"27\">\n            <i class=\"ti ti-photo text-2xl\" data-kid=\"28\"></i>\n          </div>\n          <div data-kid=\"29\">\n            <p class=\"text-sm text-gray-400 font-medium\" data-kid=\"30\">With Images</p>\n            <p class=\"text-3xl font-bold text-[#1d4e7a]\" data-kid=\"31\">18</p>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"relative overflow-hidden bg-white rounded-2xl border border-gray-100 p-6 shadow-sm group\" data-kid=\"32\">\n        <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/viscious-speed/abstract-002.svg\" class=\"absolute -top-4 -right-4 w-24 h-24 opacity-5 group-hover:opacity-10 transition-opacity\" style=\"filter: invert(34%) sepia(85%) saturate(415%) hue-rotate(165deg) brightness(92%) contrast(88%);\" data-kid=\"33\">\n        <div class=\"relative z-10 flex items-center gap-4\" data-kid=\"34\">\n          <div class=\"w-14 h-14 rounded-2xl bg-[#e8a020]/10 flex items-center justify-center text-[#e8a020]\" data-kid=\"35\">\n            <i class=\"ti ti-link text-2xl\" data-kid=\"36\"></i>\n          </div>\n          <div data-kid=\"37\">\n            <p class=\"text-sm text-gray-400 font-medium\" data-kid=\"38\">With Links</p>\n            <p class=\"text-3xl font-bold text-[#1d4e7a]\" data-kid=\"39\">12</p>\n          </div>\n        </div>\n      </div>\n    </div>\n  </header>\n\n  \n  <main class=\"grid lg:grid-cols-[35%_65%] gap-8 items-start\" data-kid=\"40\">\n    \n    <aside class=\"sticky top-8\" data-kid=\"41\">\n      <div class=\"bg-white rounded-2xl border border-gray-100 p-8 shadow-xl shadow-[#1d4e7a]/5\" data-kid=\"42\">\n        <div class=\"flex items-center gap-3 mb-8\" data-kid=\"43\">\n          <div class=\"w-10 h-10 rounded-xl bg-gradient-to-br from-[#2d6fa3] to-[#1d4e7a] flex items-center justify-center text-white\" data-kid=\"44\">\n            <i class=\"ti ti-plus text-xl\" data-kid=\"45\"></i>\n          </div>\n          <h2 class=\"text-xl font-bold text-[#1d4e7a]\" data-kid=\"46\">Add New Award</h2>\n        </div>\n\n        <form class=\"space-y-5\" data-kid=\"47\">\n          <div data-kid=\"48\">\n            <label class=\"block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2\" data-kid=\"49\">Award Title <span class=\"text-red-500\" data-kid=\"50\">*</span></label>\n            <input type=\"text\" class=\"w-full bg-[#f8f9fa] border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-[#2d6fa3]/20 transition-all placeholder:text-gray-300\" placeholder=\"e.g. Humanitarian Excellence 2024\" data-kid=\"51\">\n          </div>\n          \n          <div data-kid=\"52\">\n            <label class=\"block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2\" data-kid=\"53\">Awarding Organization <span class=\"text-red-500\" data-kid=\"54\">*</span></label>\n            <input type=\"text\" class=\"w-full bg-[#f8f9fa] border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-[#2d6fa3]/20 transition-all placeholder:text-gray-300\" placeholder=\"e.g. Ministry of Foreign Affairs\" data-kid=\"55\">\n          </div>\n\n          <div class=\"grid grid-cols-2 gap-4\" data-kid=\"56\">\n            <div data-kid=\"57\">\n              <label class=\"block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2\" data-kid=\"58\">Recipient</label>\n              <input type=\"text\" class=\"w-full bg-[#f8f9fa] border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-[#2d6fa3]/20 transition-all placeholder:text-gray-300\" placeholder=\"Optional\" data-kid=\"59\">\n            </div>\n            <div data-kid=\"60\">\n              <label class=\"block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2\" data-kid=\"61\">Icon (Emoji)</label>\n              <input type=\"text\" class=\"w-full bg-[#f8f9fa] border-none rounded-xl px-4 py-3 text-sm text-center focus:ring-2 focus:ring-[#2d6fa3]/20 transition-all\" value=\"🏆\" data-kid=\"62\">\n            </div>\n          </div>\n\n          <div data-kid=\"63\">\n            <label class=\"block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2\" data-kid=\"64\">Description</label>\n            <textarea rows=\"3\" class=\"w-full bg-[#f8f9fa] border-none rounded-xl px-4 py-3 text-sm focus:ring-2 focus:ring-[#2d6fa3]/20 transition-all placeholder:text-gray-300 resize-none\" placeholder=\"Provide a brief background...\" data-kid=\"65\"></textarea>\n          </div>\n\n          <div data-kid=\"66\">\n            <label class=\"block text-xs font-bold text-gray-400 uppercase tracking-wider mb-2\" data-kid=\"67\">Media Upload</label>\n            <div class=\"border-2 border-dashed border-gray-100 bg-[#f8f9fa] rounded-2xl p-6 text-center cursor-pointer hover:border-[#2d6fa3]/30 transition-all group\" data-kid=\"68\">\n              <i class=\"ti ti-cloud-upload text-3xl text-gray-300 group-hover:text-[#2d6fa3] transition-colors mb-2 block\" data-kid=\"69\"></i>\n              <p class=\"text-xs font-medium text-gray-500\" data-kid=\"70\">Drag & drop or <span class=\"text-[#2d6fa3] underline\" data-kid=\"71\">browse</span></p>\n              <p class=\"text-[10px] text-gray-400 mt-1\" data-kid=\"72\">PNG, JPG, WebP up to 5MB</p>\n            </div>\n          </div>\n\n          <div class=\"pt-4 border-t border-gray-50\" data-kid=\"73\">\n            <button type=\"submit\" class=\"w-full bg-[#2d6fa3] text-white py-4 rounded-2xl font-bold shadow-lg shadow-[#2d6fa3]/20 hover:bg-[#1d4e7a] hover:-translate-y-0.5 transition-all\" data-kid=\"74\">\n              Create Award Entry\n            </button>\n          </div>\n        </form>\n      </div>\n    </aside>\n\n    \n    <section data-kid=\"75\">\n      <div class=\"flex items-center justify-between mb-6\" data-kid=\"76\">\n        <h3 class=\"text-sm font-bold text-gray-400 uppercase tracking-widest\" data-kid=\"77\">Active Recognitions (24)</h3>\n        <div class=\"flex items-center gap-2\" data-kid=\"78\">\n          <button class=\"w-8 h-8 rounded-lg bg-white border border-gray-100 flex items-center justify-center text-[#2d6fa3] shadow-sm\" data-kid=\"79\"><i class=\"ti ti-layout-grid\" data-kid=\"80\"></i></button>\n          <button class=\"w-8 h-8 rounded-lg bg-gray-50 text-gray-400 flex items-center justify-center\" data-kid=\"81\"><i class=\"ti ti-list\" data-kid=\"82\"></i></button>\n        </div>\n      </div>\n\n      <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\" data-kid=\"83\">\n        \n        <article class=\"bg-white rounded-3xl border border-gray-100 overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-500 flex flex-col group\" data-kid=\"84\">\n          <div class=\"h-48 relative overflow-hidden\" data-kid=\"85\">\n            <img src=\"https://images.unsplash.com/photo-1593113598332-cd288d649433?auto=format&w=800&q=80&fit=crop\" alt=\"Joel Muniz on Unsplash\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" loading=\"lazy\" decoding=\"async\" data-kid=\"86\">\n            <div class=\"absolute inset-0 bg-gradient-to-t from-black/60 to-transparent\" data-kid=\"87\"></div>\n            <div class=\"absolute bottom-4 left-4\" data-kid=\"88\">\n              <span class=\"bg-[#8da83a] text-white text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full\" data-kid=\"89\">Humanitarian Prize</span>\n            </div>\n          </div>\n          <div class=\"p-6 flex-grow flex flex-col\" data-kid=\"90\">\n            <h4 class=\"text-lg font-bold text-[#1d4e7a] mb-1\" data-kid=\"91\">Human Rights Hero Award</h4>\n            <p class=\"text-sm text-[#2d6fa3] font-medium mb-4\" data-kid=\"92\">Ministry of Cambodia</p>\n            <p class=\"text-sm text-gray-500 leading-relaxed mb-6 line-clamp-3\" data-kid=\"93\">Recognized for extraordinary commitment to children's education and sustainable development in rural communities.</p>\n            \n            <div class=\"mt-auto pt-6 border-t border-gray-50 flex items-center justify-between\" data-kid=\"94\">\n              <a href=\"#\" class=\"inline-flex items-center gap-1.5 text-xs font-bold text-[#2d6fa3] hover:text-[#1d4e7a] transition-colors\" data-kid=\"95\">\n                VIEW WEBSITE <i class=\"ti ti-external-link\" data-kid=\"96\"></i>\n              </a>\n              <div class=\"flex items-center gap-1\" data-kid=\"97\">\n                <button class=\"w-8 h-8 rounded-lg bg-gray-50 text-gray-400 hover:text-[#2d6fa3] hover:bg-[#2d6fa3]/5 transition-all\" data-kid=\"98\"><i class=\"ti ti-edit\" data-kid=\"99\"></i></button>\n                <button class=\"w-8 h-8 rounded-lg bg-gray-50 text-gray-400 hover:text-red-500 hover:bg-red-50 transition-all\" data-kid=\"100\"><i class=\"ti ti-trash\" data-kid=\"101\"></i></button>\n              </div>\n            </div>\n          </div>\n        </article>\n\n        \n        <article class=\"bg-white rounded-3xl border border-gray-100 overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-500 flex flex-col group\" data-kid=\"102\">\n          <div class=\"h-48 relative overflow-hidden\" data-kid=\"103\">\n            <img src=\"https://images.pexels.com/photos/6646907/pexels-photo-6646907.jpeg?auto=compress&cs=tinysrgb&w=800&q=80\" alt=\"RDNE Stock project on Pexels\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" loading=\"lazy\" decoding=\"async\" data-kid=\"104\">\n            <div class=\"absolute inset-0 bg-gradient-to-t from-black/60 to-transparent\" data-kid=\"105\"></div>\n            <div class=\"absolute bottom-4 left-4 text-white\" data-kid=\"106\">\n               <span class=\"bg-[#e8a020] text-white text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full\" data-kid=\"107\">National Recognition</span>\n            </div>\n          </div>\n          <div class=\"p-6 flex-grow flex flex-col\" data-kid=\"108\">\n            <h4 class=\"text-lg font-bold text-[#1d4e7a] mb-1\" data-kid=\"109\">Volunteer Excellence Medal</h4>\n            <p class=\"text-sm text-[#2d6fa3] font-medium mb-4\" data-kid=\"110\">UNESCO Regional Office</p>\n            <p class=\"text-sm text-gray-500 leading-relaxed mb-6 line-clamp-3\" data-kid=\"111\">Awarded for the development of innovative community outreach programs that have reached over 50,000 households.</p>\n            \n            <div class=\"mt-auto pt-6 border-t border-gray-50 flex items-center justify-between\" data-kid=\"112\">\n              <a href=\"#\" class=\"inline-flex items-center gap-1.5 text-xs font-bold text-[#2d6fa3] hover:text-[#1d4e7a] transition-colors\" data-kid=\"113\">\n                READ ARTICLE <i class=\"ti ti-news\" data-kid=\"114\"></i>\n              </a>\n              <div class=\"flex items-center gap-1\" data-kid=\"115\">\n                <button class=\"w-8 h-8 rounded-lg bg-gray-50 text-gray-400 hover:text-[#2d6fa3] hover:bg-[#2d6fa3]/5 transition-all\" data-kid=\"116\"><i class=\"ti ti-edit\" data-kid=\"117\"></i></button>\n                <button class=\"w-8 h-8 rounded-lg bg-gray-50 text-gray-400 hover:text-red-500 hover:bg-red-50 transition-all\" data-kid=\"118\"><i class=\"ti ti-trash\" data-kid=\"119\"></i></button>\n              </div>\n            </div>\n          </div>\n        </article>\n\n        \n        <article class=\"bg-white rounded-3xl border border-gray-100 overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-500 flex flex-col group\" data-kid=\"120\">\n          <div class=\"h-48 relative overflow-hidden bg-gradient-to-br from-[#1d4e7a] to-[#2d6fa3] flex items-center justify-center\" data-kid=\"121\">\n            <i class=\"ti ti-award text-7xl text-white/20 group-hover:scale-125 transition-transform duration-700\" data-kid=\"122\"></i>\n            <span class=\"absolute text-7xl group-hover:scale-110 transition-transform duration-500\" data-kid=\"123\">🏅</span>\n            <div class=\"absolute bottom-4 left-4\" data-kid=\"124\">\n              <span class=\"bg-white/20 backdrop-blur-md text-white text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full border border-white/10\" data-kid=\"125\">NGO Achievement</span>\n            </div>\n          </div>\n          <div class=\"p-6 flex-grow flex flex-col\" data-kid=\"126\">\n            <h4 class=\"text-lg font-bold text-[#1d4e7a] mb-1\" data-kid=\"127\">Impact Innovator 2023</h4>\n            <p class=\"text-sm text-[#2d6fa3] font-medium mb-4\" data-kid=\"128\">Global Philanthropy Network</p>\n            <p class=\"text-sm text-gray-500 leading-relaxed mb-6 line-clamp-3\" data-kid=\"129\">Recognizing the most impactful use of digital tools for field coordination in Southeast Asian humanitarian efforts.</p>\n            \n            <div class=\"mt-auto pt-6 border-t border-gray-50 flex items-center justify-between\" data-kid=\"130\">\n              <span class=\"text-[10px] font-bold text-gray-300 uppercase tracking-widest\" data-kid=\"131\">No External Link</span>\n              <div class=\"flex items-center gap-1\" data-kid=\"132\">\n                <button class=\"w-8 h-8 rounded-lg bg-gray-50 text-gray-400 hover:text-[#2d6fa3] hover:bg-[#2d6fa3]/5 transition-all\" data-kid=\"133\"><i class=\"ti ti-edit\" data-kid=\"134\"></i></button>\n                <button class=\"w-8 h-8 rounded-lg bg-gray-50 text-gray-400 hover:text-red-500 hover:bg-red-50 transition-all\" data-kid=\"135\"><i class=\"ti ti-trash\" data-kid=\"136\"></i></button>\n              </div>\n            </div>\n          </div>\n        </article>\n\n        \n        <article class=\"bg-white rounded-3xl border border-gray-100 overflow-hidden shadow-sm hover:shadow-xl hover:-translate-y-1 transition-all duration-500 flex flex-col group\" data-kid=\"137\">\n          <div class=\"h-48 relative overflow-hidden bg-[#8da83a]/10 flex items-center justify-center\" data-kid=\"138\">\n            <img src=\"https://images.unsplash.com/photo-1628717341663-0007b0ee2597?auto=format&w=800&q=80&fit=crop\" alt=\"Ismael Paramo on Unsplash\" class=\"w-full h-full object-cover group-hover:scale-110 transition-transform duration-700\" loading=\"lazy\" decoding=\"async\" data-kid=\"139\">\n            <div class=\"absolute inset-0 bg-gradient-to-t from-black/60 to-transparent\" data-kid=\"140\"></div>\n            <div class=\"absolute bottom-4 left-4\" data-kid=\"141\">\n               <span class=\"bg-[#2d6fa3] text-white text-[10px] font-bold uppercase tracking-widest px-3 py-1 rounded-full\" data-kid=\"142\">Community Hero</span>\n            </div>\n          </div>\n          <div class=\"p-6 flex-grow flex flex-col\" data-kid=\"143\">\n            <h4 class=\"text-lg font-bold text-[#1d4e7a] mb-1\" data-kid=\"144\">Local Outreach Award</h4>\n            <p class=\"text-sm text-[#2d6fa3] font-medium mb-4\" data-kid=\"145\">Battambang Municipality</p>\n            <p class=\"text-sm text-gray-500 leading-relaxed mb-6 line-clamp-3\" data-kid=\"146\">Special recognition for the swift response and support provided to families during the 2023 monsoon season.</p>\n            \n            <div class=\"mt-auto pt-6 border-t border-gray-50 flex items-center justify-between\" data-kid=\"147\">\n              <a href=\"#\" class=\"inline-flex items-center gap-1.5 text-xs font-bold text-[#2d6fa3] hover:text-[#1d4e7a] transition-colors\" data-kid=\"148\">\n                WATCH VIDEO <i class=\"ti ti-player-play\" data-kid=\"149\"></i>\n              </a>\n              <div class=\"flex items-center gap-1\" data-kid=\"150\">\n                <button class=\"w-8 h-8 rounded-lg bg-gray-50 text-gray-400 hover:text-[#2d6fa3] hover:bg-[#2d6fa3]/5 transition-all\" data-kid=\"151\"><i class=\"ti ti-edit\" data-kid=\"152\"></i></button>\n                <button class=\"w-8 h-8 rounded-lg bg-gray-50 text-gray-400 hover:text-red-500 hover:bg-red-50 transition-all\" data-kid=\"153\"><i class=\"ti ti-trash\" data-kid=\"154\"></i></button>\n              </div>\n            </div>\n          </div>\n        </article>\n      </div>\n\n      \n      <div class=\"mt-12 text-center\" data-kid=\"155\">\n        <button class=\"bg-white border border-gray-100 text-[#1d4e7a] font-bold text-sm px-8 py-3 rounded-2xl shadow-sm hover:shadow-md hover:border-[#2d6fa3]/20 transition-all group\" data-kid=\"156\">\n          Load More Achievements <i class=\"ti ti-chevron-down ml-2 group-hover:translate-y-0.5 transition-transform inline-block\" data-kid=\"157\"></i>\n        </button>\n      </div>\n    </section>\n  </main>\n</div>",
      "comments": [],
      "created": "2026-07-08T11:54:16.154621+00:00",
      "modified": "2026-07-08T11:55:00.238797+00:00",
      "id": "var_f4eca2d44ff0"
    },
    "var_6aa720f4cda5": {
      "type": "variant",
      "label": "Visitor: Asymmetric Exhibition",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 4620,
        "y": 0,
        "w": 1280,
        "h": 1659
      },
      "html": "<link href=\"https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;800&family=Inter:wght@400;500;600;700&display=swap\" rel=\"stylesheet\" data-kid=\"0\">\n<link rel=\"stylesheet\" href=\"https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css\" data-kid=\"1\">\n\n<style data-kid=\"2\">\n  @layer base {\n    body {\n      font-family: 'Inter', sans-serif;\n      color: #1d4e7a;\n      background-color: #f8f9fc;\n    }\n  }\n\n  .font-playfair {\n    font-family: 'Playfair Display', serif;\n  }\n\n  .marquee-content {\n    display: flex;\n    animation: marquee 30s linear infinite;\n  }\n\n  @keyframes marquee {\n    0% { transform: translateX(0); }\n    100% { transform: translateX(-50%); }\n  }\n\n  .bento-grid {\n    display: grid;\n    grid-template-columns: repeat(4, 1fr);\n    grid-auto-rows: 280px;\n    gap: 1.5rem;\n  }\n\n  .bento-item-featured {\n    grid-column: span 2;\n    grid-row: span 2;\n  }\n\n  .bento-item-wide {\n    grid-column: span 2;\n  }\n\n  .award-card {\n    position: relative;\n    background: #153A5A;\n    border: 1px solid rgba(141, 168, 58, 0.3);\n    border-radius: 1.5rem;\n    overflow: hidden;\n    transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n\n  .award-card:hover {\n    transform: translateY(-8px);\n    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);\n    border-color: #8da83a;\n  }\n\n  .shape-mask {\n    opacity: 0.15;\n    filter: brightness(0) invert(1);\n  }\n</style>\n\n<div class=\"min-h-screen\" data-kid=\"3\">\n  \n  <section class=\"relative pt-32 pb-24 overflow-hidden\" style=\"background-image: url('https://images.unsplash.com/photo-1601662528567-526cd06f6582?auto=format&w=1280&q=80&fit=crop'); background-size: cover; background-position: center;\" data-kid=\"4\">\n    <div class=\"absolute inset-0 bg-white/40 backdrop-blur-[2px]\" data-kid=\"5\"></div>\n    \n    <div class=\"relative container mx-auto px-6 text-center z-10\" data-kid=\"6\">\n      <h2 class=\"text-[#8da83a] font-bold tracking-[0.3em] uppercase text-sm mb-6 animate-fade-in\" data-kid=\"7\">Excellence in Service</h2>\n      <h1 class=\"font-playfair text-6xl md:text-8xl font-black text-[#153A5A] leading-tight tracking-tight mb-8\" data-kid=\"8\">\n        A LEGACY OF <br data-kid=\"9\">\n        <span class=\"text-transparent bg-clip-text bg-gradient-to-r from-[#153A5A] to-[#8da83a]\" data-kid=\"10\">HUMANITY</span>\n      </h1>\n      <p class=\"text-lg text-[#1d4e7a]/80 max-w-2xl mx-auto leading-relaxed mb-12\" data-kid=\"11\">\n        Through dedication and collective effort, we've been recognized globally for our commitment to Cambodian children and communities.\n      </p>\n    </div>\n\n    \n    <div class=\"relative mt-12 py-8 border-y border-[#153A5A]/10 bg-white/20 backdrop-blur-md\" data-kid=\"12\">\n      <div class=\"flex overflow-hidden whitespace-nowrap\" data-kid=\"13\">\n        <div class=\"marquee-content flex items-center gap-24 px-12\" data-kid=\"14\">\n          \n          <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/wrapping-star.svg\" class=\"w-12 h-12 text-[#8da83a]/30\" style=\"color: #8da83a; opacity: 0.3;\" data-kid=\"15\">\n          <span class=\"font-playfair italic text-2xl tracking-[0.2em] text-[#153A5A]/40 uppercase\" data-kid=\"16\">Global Recognition</span>\n          <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/ribbon-medal.svg\" class=\"w-12 h-12 text-[#8da83a]/30\" style=\"color: #8da83a; opacity: 0.3;\" data-kid=\"17\">\n          <span class=\"font-playfair italic text-2xl tracking-[0.2em] text-[#153A5A]/40 uppercase\" data-kid=\"18\">Excellence</span>\n          <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/wrapping-star.svg\" class=\"w-12 h-12 text-[#8da83a]/30\" style=\"color: #8da83a; opacity: 0.3;\" data-kid=\"19\">\n          <span class=\"font-playfair italic text-2xl tracking-[0.2em] text-[#153A5A]/40 uppercase\" data-kid=\"20\">Humanitarian Impact</span>\n          <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/ribbon-medal.svg\" class=\"w-12 h-12 text-[#8da83a]/30\" style=\"color: #8da83a; opacity: 0.3;\" data-kid=\"21\">\n          \n          <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/lorc/wrapping-star.svg\" class=\"w-12 h-12 text-[#8da83a]/30\" style=\"color: #8da83a; opacity: 0.3;\" data-kid=\"22\">\n          <span class=\"font-playfair italic text-2xl tracking-[0.2em] text-[#153A5A]/40 uppercase\" data-kid=\"23\">Global Recognition</span>\n          <img src=\"https://cdn.jsdelivr.net/npm/game-icons-transparent@latest/svgs/delapouite/ribbon-medal.svg\" class=\"w-12 h-12 text-[#8da83a]/30\" style=\"color: #8da83a; opacity: 0.3;\" data-kid=\"24\">\n          <span class=\"font-playfair italic text-2xl tracking-[0.2em] text-[#153A5A]/40 uppercase\" data-kid=\"25\">Excellence</span>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"bg-[#153A5A] py-32\" data-kid=\"26\">\n    <div class=\"container mx-auto px-6\" data-kid=\"27\">\n      <div class=\"bento-grid\" data-kid=\"28\">\n        \n        <div class=\"award-card bento-item-featured group\" data-kid=\"29\">\n          <img src=\"https://images.pexels.com/photos/32660518/pexels-photo-32660518.jpeg?auto=format&w=800&q=80&fit=crop\" alt=\"Award Ceremony\" class=\"absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-110 opacity-60\" data-kid=\"30\">\n          <div class=\"absolute inset-0 bg-gradient-to-t from-[#153A5A] via-[#153A5A]/40 to-transparent\" data-kid=\"31\"></div>\n          <div class=\"absolute bottom-0 left-0 p-10 w-full\" data-kid=\"32\">\n            <span class=\"inline-block px-4 py-1.5 rounded-full bg-[#8da83a] text-white text-xs font-bold tracking-widest uppercase mb-4\" data-kid=\"33\">Featured</span>\n            <h3 class=\"font-playfair text-4xl text-white mb-4 leading-tight\" data-kid=\"34\">Chevalier de la Légion d'Honneur</h3>\n            <p class=\"text-white/70 text-sm line-clamp-2 max-w-md\" data-kid=\"35\">For exceptional services to education and social development for blind and deaf children in Cambodia.</p>\n          </div>\n        </div>\n\n        \n        <div class=\"award-card p-8 flex flex-col justify-between\" data-kid=\"36\">\n          <div class=\"flex justify-between items-start\" data-kid=\"37\">\n            <i class=\"ti ti-trophy text-4xl text-[#8da83a]\" data-kid=\"38\"></i>\n            <span class=\"font-playfair text-white/20 text-5xl font-black\" data-kid=\"39\">2024</span>\n          </div>\n          <div data-kid=\"40\">\n            <h4 class=\"font-playfair text-xl text-white tracking-[0.05em] uppercase mb-2\" data-kid=\"41\">NGO of the Year</h4>\n            <p class=\"text-[#8da83a] text-xs font-semibold uppercase tracking-wider\" data-kid=\"42\">Cambodian Govt.</p>\n          </div>\n        </div>\n\n        \n        <div class=\"award-card p-8 flex flex-col justify-between\" data-kid=\"43\">\n          <div class=\"flex justify-between items-start\" data-kid=\"44\">\n            <i class=\"ti ti-medal text-4xl text-white/40\" data-kid=\"45\"></i>\n            <span class=\"font-playfair text-white/20 text-5xl font-black\" data-kid=\"46\">2023</span>\n          </div>\n          <div data-kid=\"47\">\n            <h4 class=\"font-playfair text-xl text-white tracking-[0.05em] uppercase mb-2\" data-kid=\"48\">Social Impact Prize</h4>\n            <p class=\"text-[#8da83a] text-xs font-semibold uppercase tracking-wider\" data-kid=\"49\">UNICEF Cambodia</p>\n          </div>\n        </div>\n\n        \n        <div class=\"award-card bento-item-wide group overflow-hidden\" data-kid=\"50\">\n          <div class=\"flex h-full\" data-kid=\"51\">\n            <div class=\"w-1/2 p-8 flex flex-col justify-center\" data-kid=\"52\">\n              <h3 class=\"font-playfair text-3xl text-white mb-4\" data-kid=\"53\">King Father Sihanouk Medal</h3>\n              <p class=\"text-white/60 text-sm mb-6\" data-kid=\"54\">A prestigious recognition for the protection and integration of vulnerable children into society.</p>\n              <button class=\"w-fit text-xs font-bold text-[#8da83a] uppercase tracking-widest border-b border-[#8da83a] pb-1 hover:text-white hover:border-white transition-all\" data-kid=\"55\">View Details</button>\n            </div>\n            <div class=\"w-1/2 relative\" data-kid=\"56\">\n              <img src=\"https://images.unsplash.com/photo-1747172556451-3a8aafe7a7ed?auto=format&w=600&q=80&fit=crop\" alt=\"Outreach\" class=\"w-full h-full object-cover\" data-kid=\"57\">\n            </div>\n          </div>\n        </div>\n\n        \n        <div class=\"award-card p-8 bg-gradient-to-br from-[#1d4e7a] to-[#153A5A]\" data-kid=\"58\">\n          <h4 class=\"font-playfair text-2xl text-white mb-4\" data-kid=\"59\">Child Safety Award</h4>\n          <p class=\"text-white/50 text-xs leading-relaxed mb-6\" data-kid=\"60\">Recognized for implementing world-class child protection policies across all centers.</p>\n          <div class=\"mt-auto flex items-center gap-2\" data-kid=\"61\">\n            <div class=\"w-8 h-8 rounded-full bg-[#8da83a] flex items-center justify-center\" data-kid=\"62\">\n              <i class=\"ti ti-award text-white text-lg\" data-kid=\"63\"></i>\n            </div>\n            <span class=\"text-white/80 text-[10px] font-bold uppercase tracking-tighter\" data-kid=\"64\">Global Excellence</span>\n          </div>\n        </div>\n\n        \n        <div class=\"award-card p-8 flex flex-col border-dashed\" data-kid=\"65\">\n          <span class=\"font-playfair text-white/10 text-8xl absolute -right-4 -bottom-4 select-none\" data-kid=\"66\">#1</span>\n          <div class=\"mb-4\" data-kid=\"67\">\n             <i class=\"ti ti-certificate text-3xl text-[#8da83a]\" data-kid=\"68\"></i>\n          </div>\n          <h4 class=\"font-playfair text-xl text-white uppercase tracking-wider leading-snug\" data-kid=\"69\">Excellence in Disability Inclusion</h4>\n          <p class=\"mt-2 text-white/40 text-[11px] uppercase tracking-[0.2em]\" data-kid=\"70\">ASEAN Development Fund</p>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  \n  <section class=\"py-24 bg-white\" data-kid=\"71\">\n    <div class=\"container mx-auto px-6\" data-kid=\"72\">\n      <div class=\"max-w-4xl mx-auto flex flex-col md:flex-row items-center gap-12\" data-kid=\"73\">\n        <div class=\"flex-1 text-center md:text-left\" data-kid=\"74\">\n          <h3 class=\"font-playfair text-4xl text-[#153A5A] mb-4\" data-kid=\"75\">\"Recognition is just a milestone. The real reward is their future.\"</h3>\n          <p class=\"text-[#1d4e7a]/60 font-medium italic\" data-kid=\"76\">Join us in creating more stories of success and resilience.</p>\n        </div>\n        <div class=\"flex-shrink-0\" data-kid=\"77\">\n          <a href=\"#\" class=\"inline-flex items-center gap-4 bg-[#153A5A] text-white px-10 py-5 rounded-full font-bold uppercase tracking-widest hover:bg-[#8da83a] hover:scale-105 transition-all shadow-xl shadow-[#153A5A]/20\" data-kid=\"78\">\n            Make an Impact\n            <i class=\"ti ti-arrow-right text-xl\" data-kid=\"79\"></i>\n          </a>\n        </div>\n      </div>\n    </div>\n  </section>\n</div>\n\n\n<div class=\"fixed inset-0 bg-[#153A5A]/95 hidden z-50 items-center justify-center p-8 backdrop-blur-xl\" data-kid=\"80\">\n  <div class=\"bg-white rounded-[2rem] max-w-4xl w-full flex overflow-hidden shadow-2xl\" data-kid=\"81\">\n    <div class=\"w-1/2 bg-[#1d4e7a] p-12 flex items-center justify-center\" data-kid=\"82\">\n      <img src=\"https://images.pexels.com/photos/32660518/pexels-photo-32660518.jpeg?auto=format&w=600&q=80\" class=\"w-64 h-64 object-cover rounded-2xl shadow-2xl shadow-black/40\" data-kid=\"83\">\n    </div>\n    <div class=\"w-1/2 p-12 relative\" data-kid=\"84\">\n      <button class=\"absolute top-8 right-8 text-[#153A5A]/30 hover:text-[#153A5A]\" data-kid=\"85\"><i class=\"ti ti-x text-2xl\" data-kid=\"86\"></i></button>\n      <span class=\"text-[#8da83a] text-xs font-black uppercase tracking-widest mb-4 block\" data-kid=\"87\">Organization: French Republic</span>\n      <h3 class=\"font-playfair text-4xl text-[#153A5A] mb-6\" data-kid=\"88\">Chevalier de la Légion d'Honneur</h3>\n      <div class=\"space-y-6\" data-kid=\"89\">\n        <div data-kid=\"90\">\n          <h5 class=\"text-[10px] font-black uppercase text-[#153A5A]/40 tracking-widest mb-1\" data-kid=\"91\">Recipient</h5>\n          <p class=\"text-[#1d4e7a] font-semibold\" data-kid=\"92\">Benito Higgins (Founder)</p>\n        </div>\n        <div data-kid=\"93\">\n          <h5 class=\"text-[10px] font-black uppercase text-[#153A5A]/40 tracking-widest mb-1\" data-kid=\"94\">Description</h5>\n          <p class=\"text-[#1d4e7a]/70 text-sm leading-relaxed\" data-kid=\"95\">Recognized for three decades of tireless work building educational infrastructures for thousands of children with sensory disabilities in Cambodia.</p>\n        </div>\n        <a href=\"#\" class=\"inline-flex items-center gap-2 bg-[#8da83a] text-white px-6 py-3 rounded-xl text-sm font-bold uppercase tracking-wider hover:brightness-110 transition-all\" data-kid=\"96\">\n          Read Full Article\n          <i class=\"ti ti-external-link\" data-kid=\"97\"></i>\n        </a>\n      </div>\n    </div>\n  </div>\n</div>",
      "comments": [],
      "created": "2026-07-08T11:54:16.508913+00:00",
      "modified": "2026-07-08T11:54:45.611026+00:00",
