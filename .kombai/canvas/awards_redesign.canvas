      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  .font-sans { font-family: 'Inter', sans-serif; }\n  .font-display { font-family: 'Playfair Display', serif; }\n\n  /* Custom Scrollbar */\n  .custom-scrollbar::-webkit-scrollbar {\n    width: 6px;\n  }\n  .custom-scrollbar::-webkit-scrollbar-track {\n    background: transparent;\n  }\n  .custom-scrollbar::-webkit-scrollbar-thumb {\n    background: #e2e8f0;\n    border-radius: 10px;\n  }\n  .custom-scrollbar::-webkit-scrollbar-thumb:hover {\n    background: #cbd5e1;\n  }\n\n  .pane-active {\n    background-color: #f1f5f9;\n    border-left: 3px solid #2d6fa3;\n  }\n</style>\n\n<div class=\"font-sans flex h-screen bg-[#f8f9fc] text-[#1a202c] overflow-hidden\" data-kid=\"1\">\n  \n  \n  <aside class=\"w-[20%] border-r border-gray-200 flex flex-col p-6 bg-white overflow-y-auto custom-scrollbar\" data-kid=\"2\">\n    <div class=\"mb-8\" data-kid=\"3\">\n      <h2 class=\"font-display text-2xl text-[#1a3c6e] mb-1\" data-kid=\"4\">Awards</h2>\n      <p class=\"text-xs text-gray-400\" data-kid=\"5\">Control Center</p>\n    </div>\n\n    \n    <div class=\"space-y-4 mb-10\" data-kid=\"6\">\n      <div class=\"p-4 rounded-2xl bg-gradient-to-br from-[#2d6fa3]/5 to-transparent border border-[#2d6fa3]/10\" data-kid=\"7\">\n        <p class=\"text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1\" data-kid=\"8\">Total Awards</p>\n        <div class=\"flex items-center justify-between\" data-kid=\"9\">\n          <span class=\"text-3xl font-bold text-[#1a3c6e]\" data-kid=\"10\">24</span>\n          <div class=\"w-10 h-10 rounded-xl bg-[#2d6fa3] flex items-center justify-center text-white shadow-lg\" data-kid=\"11\">\n            <i class=\"ti ti-award text-xl\" data-kid=\"12\"></i>\n          </div>\n        </div>\n      </div>\n      \n      <div class=\"p-4 rounded-2xl bg-gradient-to-br from-[#8da83a]/5 to-transparent border border-[#8da83a]/10\" data-kid=\"13\">\n        <p class=\"text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1\" data-kid=\"14\">With Images</p>\n        <div class=\"flex items-center justify-between\" data-kid=\"15\">\n          <span class=\"text-3xl font-bold text-[#1a3c6e]\" data-kid=\"16\">18</span>\n          <div class=\"w-10 h-10 rounded-xl bg-[#8da83a] flex items-center justify-center text-white shadow-lg\" data-kid=\"17\">\n            <i class=\"ti ti-photo text-xl\" data-kid=\"18\"></i>\n          </div>\n        </div>\n      </div>\n\n      <div class=\"p-4 rounded-2xl bg-gradient-to-br from-[#e8a020]/5 to-transparent border border-[#e8a020]/10\" data-kid=\"19\">\n        <p class=\"text-xs font-semibold text-gray-400 uppercase tracking-wider mb-1\" data-kid=\"20\">With Links</p>\n        <div class=\"flex items-center justify-between\" data-kid=\"21\">\n          <span class=\"text-3xl font-bold text-[#1a3c6e]\" data-kid=\"22\">12</span>\n          <div class=\"w-10 h-10 rounded-xl bg-[#e8a020] flex items-center justify-center text-white shadow-lg\" data-kid=\"23\">\n            <i class=\"ti ti-external-link text-xl\" data-kid=\"24\"></i>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"mt-auto\" data-kid=\"25\">\n      <h3 class=\"text-xs font-bold text-gray-500 uppercase tracking-widest mb-4 flex items-center gap-2\" data-kid=\"26\">\n        <i class=\"ti ti-filter\" data-kid=\"27\"></i> Filters\n      </h3>\n      <div class=\"space-y-2\" data-kid=\"28\">\n        <button class=\"w-full text-left px-4 py-2.5 rounded-xl text-sm font-medium bg-[#2d6fa3] text-white shadow-md\" data-kid=\"29\">\n          Show All\n        </button>\n        <button class=\"w-full text-left px-4 py-2.5 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-100 transition-colors\" data-kid=\"30\">\n          With Images Only\n        </button>\n        <button class=\"w-full text-left px-4 py-2.5 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-100 transition-colors\" data-kid=\"31\">\n          External Links\n        </button>\n        <button class=\"w-full text-left px-4 py-2.5 rounded-xl text-sm font-medium text-gray-600 hover:bg-gray-100 transition-colors\" data-kid=\"32\">\n          Recent First\n        </button>\n      </div>\n    </div>\n  </aside>\n\n  \n  <main class=\"w-[40%] border-r border-gray-200 flex flex-col bg-white\" data-kid=\"33\">\n    <div class=\"p-6 border-b border-gray-100 flex items-center justify-between\" data-kid=\"34\">\n      <div class=\"relative flex-grow max-w-xs\" data-kid=\"35\">\n        <span class=\"absolute inset-y-0 left-3 flex items-center text-gray-400\" data-kid=\"36\">\n          <i class=\"ti ti-search\" data-kid=\"37\"></i>\n        </span>\n        <input type=\"text\" placeholder=\"Search awards...\" class=\"w-full pl-10 pr-4 py-2 rounded-xl bg-gray-50 border-none text-sm focus:ring-2 focus:ring-[#2d6fa3]/20\" data-kid=\"38\">\n      </div>\n      <button class=\"p-2 text-gray-400 hover:text-[#2d6fa3] transition-colors\" data-kid=\"39\">\n        <i class=\"ti ti-adjustments-horizontal text-xl\" data-kid=\"40\"></i>\n      </button>\n    </div>\n\n    <div class=\"flex-grow overflow-y-auto custom-scrollbar\" data-kid=\"41\">\n      \n      <div class=\"divide-y divide-gray-50\" data-kid=\"42\">\n        \n        <div class=\"p-5 flex items-center gap-4 hover:bg-gray-50 cursor-pointer transition-all border-l-4 border-[#2d6fa3] bg-[#2d6fa3]/5\" data-kid=\"43\">\n          <div class=\"w-14 h-14 rounded-2xl bg-white shadow-sm border border-gray-100 flex items-center justify-center overflow-hidden shrink-0\" data-kid=\"44\">\n             <img src=\"https://images.unsplash.com/photo-1593113598332-cd288d649433?auto=format&w=200&q=80&fit=crop\" alt=\"Award Image\" class=\"w-full h-full object-cover\" data-kid=\"45\">\n          </div>\n          <div class=\"min-w-0\" data-kid=\"46\">\n            <h4 class=\"font-semibold text-gray-800 text-sm truncate\" data-kid=\"47\">Gold Humanitarian Medal</h4>\n            <p class=\"text-xs text-[#2d6fa3] font-medium\" data-kid=\"48\">Kingdom of Cambodia</p>\n            <p class=\"text-[10px] text-gray-400 mt-1 uppercase tracking-tighter\" data-kid=\"49\">Recipient: Benoît Duchâteau-Arminjon</p>\n          </div>\n          <div class=\"ml-auto text-gray-300\" data-kid=\"50\">\n            <i class=\"ti ti-chevron-right\" data-kid=\"51\"></i>\n          </div>\n        </div>\n\n        \n        <div class=\"p-5 flex items-center gap-4 hover:bg-gray-50 cursor-pointer transition-all border-l-4 border-transparent\" data-kid=\"52\">\n          <div class=\"w-14 h-14 rounded-2xl bg-gradient-to-br from-[#1a3c6e] to-[#2d6fa3] shadow-sm flex items-center justify-center shrink-0\" data-kid=\"53\">\n             <span class=\"text-2xl\" data-kid=\"54\">🏆</span>\n          </div>\n          <div class=\"min-w-0\" data-kid=\"55\">\n            <h4 class=\"font-semibold text-gray-800 text-sm truncate\" data-kid=\"56\">ASEAN Social Impact Award</h4>\n            <p class=\"text-xs text-[#2d6fa3] font-medium\" data-kid=\"57\">ASEAN Foundation</p>\n            <p class=\"text-[10px] text-gray-400 mt-1 uppercase tracking-tighter\" data-kid=\"58\">Recipient: Krousar Thmey Organization</p>\n          </div>\n          <div class=\"ml-auto text-gray-300\" data-kid=\"59\">\n            <i class=\"ti ti-chevron-right\" data-kid=\"60\"></i>\n          </div>\n        </div>\n\n        \n        <div class=\"p-5 flex items-center gap-4 hover:bg-gray-50 cursor-pointer transition-all border-l-4 border-transparent\" data-kid=\"61\">\n          <div class=\"w-14 h-14 rounded-2xl bg-white shadow-sm border border-gray-100 flex items-center justify-center overflow-hidden shrink-0\" data-kid=\"62\">\n             <img src=\"https://images.unsplash.com/photo-1559027615-cd4628902d4a?auto=format&w=200&q=80&fit=crop\" alt=\"Award Image\" class=\"w-full h-full object-cover\" data-kid=\"63\">\n          </div>\n          <div class=\"min-w-0\" data-kid=\"64\">\n            <h4 class=\"font-semibold text-gray-800 text-sm truncate\" data-kid=\"65\">Children's Rights Hero</h4>\n            <p class=\"text-xs text-[#2d6fa3] font-medium\" data-kid=\"66\">World's Children's Prize</p>\n            <p class=\"text-[10px] text-gray-400 mt-1 uppercase tracking-tighter\" data-kid=\"67\">Recipient: Cambodia Program Team</p>\n          </div>\n          <div class=\"ml-auto text-gray-300\" data-kid=\"68\">\n            <i class=\"ti ti-chevron-right\" data-kid=\"69\"></i>\n          </div>\n        </div>\n\n        \n        <div class=\"p-5 flex items-center gap-4 hover:bg-gray-50 cursor-pointer transition-all border-l-4 border-transparent\" data-kid=\"70\">\n          <div class=\"w-14 h-14 rounded-2xl bg-gradient-to-br from-[#8da83a] to-[#6b8a2b] shadow-sm flex items-center justify-center shrink-0\" data-kid=\"71\">\n             <span class=\"text-2xl\" data-kid=\"72\">🎖️</span>\n          </div>\n          <div class=\"min-w-0\" data-kid=\"73\">\n            <h4 class=\"font-semibold text-gray-800 text-sm truncate\" data-kid=\"74\">Knight of the National Order</h4>\n            <p class=\"text-xs text-[#2d6fa3] font-medium\" data-kid=\"75\">French Republic</p>\n            <p class=\"text-[10px] text-gray-400 mt-1 uppercase tracking-tighter\" data-kid=\"76\">Recipient: Foundation Board</p>\n          </div>\n          <div class=\"ml-auto text-gray-300\" data-kid=\"77\">\n            <i class=\"ti ti-chevron-right\" data-kid=\"78\"></i>\n          </div>\n        </div>\n\n        \n        <div class=\"p-5 flex items-center gap-4 hover:bg-gray-50 cursor-pointer transition-all border-l-4 border-transparent\" data-kid=\"79\">\n          <div class=\"w-14 h-14 rounded-2xl bg-white shadow-sm border border-gray-100 flex items-center justify-center overflow-hidden shrink-0\" data-kid=\"80\">\n             <img src=\"https://images.pexels.com/photos/6646892/pexels-photo-6646892.jpeg?auto=compress&cs=tinysrgb&w=200&q=80\" alt=\"Award Image\" class=\"w-full h-full object-cover\" data-kid=\"81\">\n          </div>\n          <div class=\"min-w-0\" data-kid=\"82\">\n            <h4 class=\"font-semibold text-gray-800 text-sm truncate\" data-kid=\"83\">UNESCO Confucius Prize</h4>\n            <p class=\"text-xs text-[#2d6fa3] font-medium\" data-kid=\"84\">UNESCO</p>\n            <p class=\"text-[10px] text-gray-400 mt-1 uppercase tracking-tighter\" data-kid=\"85\">Literacy Program Recognition</p>\n          </div>\n          <div class=\"ml-auto text-gray-300\" data-kid=\"86\">\n            <i class=\"ti ti-chevron-right\" data-kid=\"87\"></i>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"p-4 bg-gray-50 border-t border-gray-100 flex items-center justify-between\" data-kid=\"88\">\n      <span class=\"text-xs text-gray-500\" data-kid=\"89\">24 Awards Listed</span>\n      <div class=\"flex gap-1\" data-kid=\"90\">\n         <button class=\"w-8 h-8 rounded-lg bg-white border border-gray-200 flex items-center justify-center text-gray-400 hover:text-[#2d6fa3]\" data-kid=\"91\">\n           <i class=\"ti ti-chevron-left\" data-kid=\"92\"></i>\n         </button>\n         <button class=\"w-8 h-8 rounded-lg bg-white border border-gray-200 flex items-center justify-center text-gray-400 hover:text-[#2d6fa3]\" data-kid=\"93\">\n           <i class=\"ti ti-chevron-right\" data-kid=\"94\"></i>\n         </button>\n      </div>\n    </div>\n  </main>\n\n  \n  <section class=\"w-[40%] bg-white flex flex-col overflow-hidden relative shadow-[-10px_0_30px_rgba(0,0,0,0.02)]\" data-kid=\"95\">\n    \n    \n    <div class=\"p-8 pb-4 flex items-center justify-between bg-white z-10\" data-kid=\"96\">\n      <div data-kid=\"97\">\n        <h3 class=\"text-xl font-bold text-[#1a3c6e]\" data-kid=\"98\">Edit Award</h3>\n        <p class=\"text-xs text-gray-400\" data-kid=\"99\">Manage all details for this entry</p>\n      </div>\n      <div class=\"flex gap-2\" data-kid=\"100\">\n         <button class=\"w-10 h-10 rounded-xl bg-red-50 text-red-500 flex items-center justify-center hover:bg-red-100 transition-colors\" title=\"Delete Award\" data-kid=\"101\">\n           <i class=\"ti ti-trash\" data-kid=\"102\"></i>\n         </button>\n         <button class=\"px-5 py-2 rounded-xl bg-[#2d6fa3] text-white text-sm font-semibold shadow-lg shadow-[#2d6fa3]/20 hover:scale-105 transition-transform\" data-kid=\"103\">\n           Save Changes\n         </button>\n      </div>\n    </div>\n\n    <div class=\"flex-grow overflow-y-auto p-8 pt-0 custom-scrollbar\" data-kid=\"104\">\n      <form class=\"space-y-6\" data-kid=\"105\">\n        \n        \n        <div class=\"relative group\" data-kid=\"106\">\n          <label class=\"block text-xs font-bold text-gray-400 uppercase tracking-widest mb-3\" data-kid=\"107\">Award Asset</label>\n          <div class=\"w-full h-56 rounded-3xl bg-gray-50 border-2 border-dashed border-gray-200 flex flex-col items-center justify-center relative overflow-hidden group-hover:border-[#2d6fa3]/50 transition-colors cursor-pointer\" data-kid=\"108\">\n            <img src=\"https://images.unsplash.com/photo-1593113598332-cd288d649433?auto=format&w=800&q=80&fit=crop\" class=\"absolute inset-0 w-full h-full object-cover opacity-60 group-hover:scale-110 transition-transform duration-700\" data-kid=\"109\">\n            <div class=\"absolute inset-0 bg-gradient-to-t from-black/60 via-transparent to-transparent\" data-kid=\"110\"></div>\n            \n            <div class=\"relative z-10 text-center\" data-kid=\"111\">\n              <div class=\"w-12 h-12 rounded-2xl bg-white/20 backdrop-blur-md border border-white/30 flex items-center justify-center text-white mx-auto mb-3 shadow-xl\" data-kid=\"112\">\n                <i class=\"ti ti-cloud-upload text-2xl\" data-kid=\"113\"></i>\n              </div>\n              <p class=\"text-white text-sm font-semibold\" data-kid=\"114\">Change Image</p>\n              <p class=\"text-white/60 text-[10px] mt-1\" data-kid=\"115\">Recommended: 800x600px, Max 2MB</p>\n            </div>\n          </div>\n        </div>\n\n        <div class=\"grid grid-cols-2 gap-6\" data-kid=\"116\">\n          <div class=\"col-span-2\" data-kid=\"117\">\n            <label class=\"block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2\" data-kid=\"118\">Award Title</label>\n            <input type=\"text\" value=\"Gold Humanitarian Medal\" class=\"w-full px-5 py-3 rounded-2xl bg-gray-50 border-transparent focus:bg-white focus:ring-2 focus:ring-[#2d6fa3]/20 focus:border-[#2d6fa3] transition-all text-sm font-medium\" data-kid=\"119\">\n          </div>\n\n          <div data-kid=\"120\">\n            <label class=\"block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2\" data-kid=\"121\">Organization</label>\n            <input type=\"text\" value=\"Kingdom of Cambodia\" class=\"w-full px-5 py-3 rounded-2xl bg-gray-50 border-transparent focus:bg-white focus:ring-2 focus:ring-[#2d6fa3]/20 focus:border-[#2d6fa3] transition-all text-sm\" data-kid=\"122\">\n          </div>\n\n          <div data-kid=\"123\">\n            <label class=\"block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2\" data-kid=\"124\">Recipient</label>\n            <input type=\"text\" value=\"Benoît Duchâteau-Arminjon\" class=\"w-full px-5 py-3 rounded-2xl bg-gray-50 border-transparent focus:bg-white focus:ring-2 focus:ring-[#2d6fa3]/20 focus:border-[#2d6fa3] transition-all text-sm\" data-kid=\"125\">\n          </div>\n\n          <div class=\"col-span-2\" data-kid=\"126\">\n            <label class=\"block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2\" data-kid=\"127\">Description</label>\n            <textarea rows=\"4\" class=\"w-full px-5 py-3 rounded-2xl bg-gray-50 border-transparent focus:bg-white focus:ring-2 focus:ring-[#2d6fa3]/20 focus:border-[#2d6fa3] transition-all text-sm resize-none\" data-kid=\"128\">Recognized for outstanding dedication to the children of Cambodia through the creation of Krousar Thmey, the first Cambodian foundation for underprivileged children.</textarea>\n          </div>\n\n          <div data-kid=\"129\">\n            <label class=\"block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2\" data-kid=\"130\">Icon (Emoji)</label>\n            <input type=\"text\" value=\"🏆\" class=\"w-full px-5 py-3 rounded-2xl bg-gray-50 border-transparent text-center text-xl focus:bg-white focus:ring-2 focus:ring-[#2d6fa3]/20 focus:border-[#2d6fa3]\" data-kid=\"131\">\n          </div>\n\n          <div data-kid=\"132\">\n            <label class=\"block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2\" data-kid=\"133\">Sort Order</label>\n            <input type=\"number\" value=\"1\" class=\"w-full px-5 py-3 rounded-2xl bg-gray-50 border-transparent focus:bg-white focus:ring-2 focus:ring-[#2d6fa3]/20 focus:border-[#2d6fa3] transition-all text-sm\" data-kid=\"134\">\n          </div>\n        </div>\n\n        \n        <div class=\"pt-6 border-t border-gray-100\" data-kid=\"135\">\n           <div class=\"flex items-center gap-2 mb-4\" data-kid=\"136\">\n              <i class=\"ti ti-link text-[#e8a020]\" data-kid=\"137\"></i>\n              <h4 class=\"text-sm font-bold text-[#1a3c6e]\" data-kid=\"138\">External Documentation</h4>\n           </div>\n           \n           <div class=\"grid grid-cols-2 gap-6\" data-kid=\"139\">\n              <div data-kid=\"140\">\n                <label class=\"block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2\" data-kid=\"141\">Link Type</label>\n                <select class=\"w-full px-5 py-3 rounded-2xl bg-gray-50 border-transparent text-sm focus:bg-white focus:ring-2 focus:ring-[#2d6fa3]/20 focus:border-[#2d6fa3] appearance-none\" data-kid=\"142\">\n                  <option data-kid=\"143\">Website</option>\n                  <option selected data-kid=\"144\">Article</option>\n                  <option data-kid=\"145\">Video</option>\n                </select>\n              </div>\n              <div data-kid=\"146\">\n                <label class=\"block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2\" data-kid=\"147\">Link Label</label>\n                <input type=\"text\" value=\"Read the story\" class=\"w-full px-5 py-3 rounded-2xl bg-gray-50 border-transparent focus:bg-white focus:ring-2 focus:ring-[#2d6fa3]/20 focus:border-[#2d6fa3] transition-all text-sm\" data-kid=\"148\">\n              </div>\n              <div class=\"col-span-2\" data-kid=\"149\">\n                <label class=\"block text-xs font-bold text-gray-500 uppercase tracking-widest mb-2\" data-kid=\"150\">Source URL</label>\n                <input type=\"url\" value=\"https://krousar-thmey.org/awards/gold-medal\" class=\"w-full px-5 py-3 rounded-2xl bg-gray-50 border-transparent focus:bg-white focus:ring-2 focus:ring-[#2d6fa3]/20 focus:border-[#2d6fa3] transition-all text-sm\" data-kid=\"151\">\n              </div>\n           </div>\n        </div>\n      </form>\n    </div>\n\n    \n    <div class=\"absolute bottom-8 right-8 z-20\" data-kid=\"152\">\n      <button class=\"w-14 h-14 rounded-2xl bg-[#8da83a] text-white shadow-xl shadow-[#8da83a]/30 flex items-center justify-center hover:scale-110 transition-transform group\" data-kid=\"153\">\n        <i class=\"ti ti-plus text-2xl group-hover:rotate-90 transition-transform\" data-kid=\"154\"></i>\n      </button>\n    </div>\n  </section>\n</div>",
