      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --kt-blue: #2d6fa3;\n    --kt-blue-dark: #1a3c6e;\n    --kt-olive: #8da83a;\n    --kt-bg: #f8f9fc;\n    --kt-text: #1e293b;\n  }\n\n  body {\n    font-family: 'Inter', sans-serif;\n    color: var(--kt-text);\n    margin: 0;\n    padding: 0;\n  }\n</style>\n\n\n<div class=\"flex flex-col h-screen bg-white shadow-2xl border-l border-gray-100 overflow-hidden\" data-kid=\"1\">\n  \n  \n  <header class=\"flex items-center justify-between px-6 py-4 border-b border-gray-100 bg-white z-10\" data-kid=\"2\">\n    <h2 class=\"text-[11px] font-bold uppercase tracking-[0.1em] text-gray-500\" data-kid=\"3\">Create New Entry</h2>\n    <button class=\"p-2 rounded-lg hover:bg-gray-50 text-gray-400 transition-colors\" data-kid=\"4\">\n      <i class=\"ti ti-x text-lg\" data-kid=\"5\"></i>\n    </button>\n  </header>\n\n  \n  <div class=\"flex-grow overflow-y-auto px-6 py-8 space-y-8\" data-kid=\"6\">\n    \n    \n    <div class=\"space-y-6\" data-kid=\"7\">\n      <div class=\"space-y-2\" data-kid=\"8\">\n        <label class=\"block text-[10px] font-bold uppercase tracking-wider text-gray-400\" data-kid=\"9\">Award Title <span class=\"text-red-500\" data-kid=\"10\">*</span></label>\n        <input type=\"text\" placeholder=\"e.g. Humanitarian Excellence 2024\" class=\"w-full px-4 py-3 bg-gray-50/50 border border-gray-100 rounded-xl text-sm focus:outline-hidden focus:ring-2 focus:ring-[var(--kt-blue)]/20 focus:border-[var(--kt-blue)] transition-all placeholder:text-gray-300\" data-kid=\"11\">\n      </div>\n      \n      <div class=\"space-y-2\" data-kid=\"12\">\n        <label class=\"block text-[10px] font-bold uppercase tracking-wider text-gray-400\" data-kid=\"13\">Organization <span class=\"text-red-500\" data-kid=\"14\">*</span></label>\n        <input type=\"text\" placeholder=\"e.g. UNESCO\" class=\"w-full px-4 py-3 bg-gray-50/50 border border-gray-100 rounded-xl text-sm focus:outline-hidden focus:ring-2 focus:ring-[var(--kt-blue)]/20 focus:border-[var(--kt-blue)] transition-all placeholder:text-gray-300\" data-kid=\"15\">\n      </div>\n    </div>\n\n    \n    <div class=\"grid grid-cols-2 gap-4\" data-kid=\"16\">\n      <div class=\"space-y-2\" data-kid=\"17\">\n        <label class=\"block text-[10px] font-bold uppercase tracking-wider text-gray-400\" data-kid=\"18\">Recipient</label>\n        <input type=\"text\" placeholder=\"Person name (if specific)\" class=\"w-full px-4 py-3 bg-gray-50/50 border border-gray-100 rounded-xl text-sm focus:outline-hidden focus:ring-2 focus:ring-[var(--kt-blue)]/20 focus:border-[var(--kt-blue)] transition-all placeholder:text-gray-300\" data-kid=\"19\">\n      </div>\n      \n      <div class=\"space-y-2\" data-kid=\"20\">\n        <label class=\"block text-[10px] font-bold uppercase tracking-wider text-gray-400\" data-kid=\"21\">Link Type</label>\n        <div class=\"relative\" data-kid=\"22\">\n          <select class=\"w-full px-4 py-3 bg-gray-50/50 border border-gray-100 rounded-xl text-sm focus:outline-hidden focus:ring-2 focus:ring-[var(--kt-blue)]/20 focus:border-[var(--kt-blue)] transition-all appearance-none\" data-kid=\"23\">\n            <option data-kid=\"24\">None</option>\n            <option data-kid=\"25\">Website</option>\n            <option data-kid=\"26\">Article</option>\n            <option data-kid=\"27\">Video</option>\n          </select>\n          <div class=\"absolute right-4 top-1/2 -translate-y-1/2 pointer-events-none text-gray-400\" data-kid=\"28\">\n            <i class=\"ti ti-chevron-down text-sm\" data-kid=\"29\"></i>\n          </div>\n        </div>\n      </div>\n    </div>\n\n    \n    <div class=\"space-y-2\" data-kid=\"30\">\n      <label class=\"block text-[10px] font-bold uppercase tracking-wider text-gray-400\" data-kid=\"31\">Featured Media</label>\n      <div class=\"relative group cursor-pointer\" data-kid=\"32\">\n        <div class=\"w-full h-48 border-2 border-dashed border-gray-100 rounded-2xl bg-gray-50/30 flex flex-col items-center justify-center space-y-3 group-hover:bg-gray-50 group-hover:border-[var(--kt-blue)]/30 transition-all\" data-kid=\"33\">\n          <div class=\"w-12 h-12 rounded-full bg-white shadow-sm flex items-center justify-center text-[var(--kt-blue)]\" data-kid=\"34\">\n            <i class=\"ti ti-upload text-xl\" data-kid=\"35\"></i>\n          </div>\n          <div class=\"text-center\" data-kid=\"36\">\n            <p class=\"text-sm font-semibold text-gray-600\" data-kid=\"37\">Drop your file here</p>\n            <p class=\"text-[10px] text-gray-400 uppercase tracking-tight mt-1\" data-kid=\"38\">JPG, PNG or WEBP up to 2MB</p>\n          </div>\n        </div>\n        <input type=\"file\" class=\"absolute inset-0 opacity-0 cursor-pointer\" data-kid=\"39\">\n      </div>\n    </div>\n\n    \n    <div class=\"space-y-2\" data-kid=\"40\">\n      <label class=\"block text-[10px] font-bold uppercase tracking-wider text-gray-400\" data-kid=\"41\">Summary Description</label>\n      <textarea rows=\"5\" placeholder=\"Briefly describe the significance of this award...\" class=\"w-full px-4 py-3 bg-gray-50/50 border border-gray-100 rounded-xl text-sm focus:outline-hidden focus:ring-2 focus:ring-[var(--kt-blue)]/20 focus:border-[var(--kt-blue)] transition-all placeholder:text-gray-300 resize-none\" data-kid=\"42\"></textarea>\n    </div>\n\n  </div>\n\n  \n  <footer class=\"px-6 py-6 border-t border-gray-100 bg-white flex items-center justify-end gap-4\" data-kid=\"43\">\n    <button class=\"px-6 py-2.5 text-sm font-medium text-gray-500 hover:text-gray-700 transition-colors\" data-kid=\"44\">\n      Discard\n    </button>\n    <button class=\"px-6 py-2.5 bg-[var(--kt-blue)] hover:bg-[var(--kt-blue-dark)] text-white text-sm font-semibold rounded-xl shadow-md shadow-[var(--kt-blue)]/20 transition-all transform active:scale-95\" data-kid=\"45\">\n      Publish Award Entry\n    </button>\n  </footer>\n\n</div>",
