    },
    "var_2b746b1ed6cf": {
      "type": "variant",
      "label": "Visitor: Timeline of Impact",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 6000,
        "y": 0,
        "w": 1280,
        "h": 800
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700;900&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  .font-serif { font-family: 'Playfair Display', serif; }\n  .font-sans { font-family: 'Inter', sans-serif; }\n\n  /* Ticket Stub Cutout Effect */\n  .ticket-stub-left {\n    position: relative;\n    overflow: visible;\n  }\n  .ticket-stub-left::before {\n    content: '';\n    position: absolute;\n    right: -12px;\n    top: 50%;\n    transform: translateY(-50%);\n    width: 24px;\n    height: 24px;\n    background-color: #Fdfbf7;\n    border-radius: 50%;\n    z-index: 10;\n    box-shadow: inset 2px 0 4px rgba(0,0,0,0.05);\n  }\n\n  .ticket-stub-right {\n    position: relative;\n    overflow: visible;\n  }\n  .ticket-stub-right::before {\n    content: '';\n    position: absolute;\n    left: -12px;\n    top: 50%;\n    transform: translateY(-50%);\n    width: 24px;\n    height: 24px;\n    background-color: #Fdfbf7;\n    border-radius: 50%;\n    z-index: 10;\n    box-shadow: inset -2px 0 4px rgba(0,0,0,0.05);\n  }\n\n  /* Custom Scrollbar for Modal */\n  .custom-scrollbar::-webkit-scrollbar {\n    width: 6px;\n  }\n  .custom-scrollbar::-webkit-scrollbar-track {\n    background: #f1f1f1;\n  }\n  .custom-scrollbar::-webkit-scrollbar-thumb {\n    background: #1d4e7a;\n    border-radius: 10px;\n  }\n</style>\n\n<div class=\"font-sans text-[#1d4e7a] bg-[#Fdfbf7] min-h-screen selection:bg-[#8da83a]/30\" data-kid=\"1\">\n  \n  \n  <header class=\"relative bg-gradient-to-br from-[#1d4e7a] to-[#2d6fa3] pt-24 pb-32 overflow-hidden\" data-kid=\"2\">\n    <div class=\"absolute inset-0 opacity-15\" data-kid=\"3\">\n      <div class=\"absolute top-0 right-0 w-96 h-96 rounded-full bg-white/20 blur-3xl -translate-y-1/2 translate-x-1/2\" data-kid=\"4\"></div>\n      <div class=\"absolute bottom-0 left-0 w-64 h-64 rounded-full bg-[#8da83a]/40 blur-3xl translate-y-1/2 -translate-x-1/3\" data-kid=\"5\"></div>\n    </div>\n    \n    <div class=\"relative max-w-7xl mx-auto px-6 grid lg:grid-cols-[1.5fr_1fr] gap-16 items-center\" data-kid=\"6\">\n      \n      <div class=\"space-y-8 animate-in fade-in slide-in-from-left-8 duration-1000\" data-kid=\"7\">\n        <nav class=\"flex items-center gap-3 text-sm text-white/60\" data-kid=\"8\">\n          <a href=\"#\" class=\"hover:text-white transition-colors\" data-kid=\"9\">Home</a>\n          <i class=\"ti ti-chevron-right text-xs\" data-kid=\"10\"></i>\n          <span class=\"text-white\" data-kid=\"11\">Awards</span>\n        </nav>\n        <div class=\"space-y-4\" data-kid=\"12\">\n          <h1 class=\"font-serif text-5xl md:text-7xl text-white leading-tight\" data-kid=\"13\">Awards & <br data-kid=\"14\"><span class=\"text-[#8da83a]\" data-kid=\"15\">Recognitions</span></h1>\n          <p class=\"text-white/80 text-xl max-w-xl leading-relaxed\" data-kid=\"16\">Celebrating the rich history and ongoing impact of Krousar Thmey’s humanitarian work across Cambodia.</p>\n        </div>\n        <div class=\"flex items-center gap-6 pt-4\" data-kid=\"17\">\n          <div class=\"flex -space-x-3\" data-kid=\"18\">\n            <img src=\"https://i.pravatar.cc/40?u=1\" class=\"w-10 h-10 rounded-full border-2 border-white shadow-sm\" alt=\"Avatar\" data-kid=\"19\">\n            <img src=\"https://i.pravatar.cc/40?u=2\" class=\"w-10 h-10 rounded-full border-2 border-white shadow-sm\" alt=\"Avatar\" data-kid=\"20\">\n            <img src=\"https://i.pravatar.cc/40?u=3\" class=\"w-10 h-10 rounded-full border-2 border-white shadow-sm\" alt=\"Avatar\" data-kid=\"21\">\n          </div>\n          <p class=\"text-white/70 text-sm font-medium tracking-wide uppercase\" data-kid=\"22\">Recognized by Global Leaders</p>\n        </div>\n      </div>\n\n      \n      <div class=\"relative h-[450px] hidden lg:block animate-in fade-in slide-in-from-right-8 duration-1000 delay-300\" data-kid=\"23\">\n        \n        <div class=\"absolute top-0 right-10 w-64 h-80 bg-white p-3 shadow-2xl rotate-3 transform hover:rotate-0 transition-transform duration-500 z-20\" data-kid=\"24\">\n          <img src=\"https://images.pexels.com/photos/18497739/pexels-photo-18497739.jpeg?auto=format&w=600&q=80&fit=crop\" class=\"w-full h-full object-cover\" alt=\"Si Tong on Pexels\" loading=\"lazy\" decoding=\"async\" data-kid=\"25\">\n        </div>\n        \n        <div class=\"absolute bottom-4 left-0 w-64 h-80 bg-white p-3 shadow-2xl -rotate-6 transform hover:rotate-0 transition-transform duration-500 z-10\" data-kid=\"26\">\n          <img src=\"https://images.pexels.com/photos/10643462/pexels-photo-10643462.jpeg?auto=format&w=600&q=80&fit=crop\" class=\"w-full h-full object-cover\" alt=\"Ron Lach on Pexels\" loading=\"lazy\" decoding=\"async\" data-kid=\"27\">\n        </div>\n        \n        <div class=\"absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-48 h-60 bg-white p-2 shadow-2xl rotate-12 transform hover:rotate-0 transition-transform duration-500 z-30\" data-kid=\"28\">\n          <img src=\"https://images.unsplash.com/photo-1743899600614-518350939ccf?auto=format&w=500&q=80&fit=crop\" class=\"w-full h-full object-cover\" alt=\"Leiada Krözjhen on Unsplash\" loading=\"lazy\" decoding=\"async\" data-kid=\"29\">\n        </div>\n      </div>\n    </div>\n  </header>\n\n  \n  <section class=\"py-32 relative overflow-hidden\" data-kid=\"30\">\n    \n    <div class=\"absolute left-1/2 top-0 bottom-0 w-px border-l-2 border-dashed border-[#8da83a]/40 -translate-x-1/2 hidden md:block\" data-kid=\"31\"></div>\n\n    <div class=\"max-w-7xl mx-auto px-6 relative space-y-32\" data-kid=\"32\">\n      \n      \n      <div class=\"relative grid md:grid-cols-2 gap-12 items-center\" data-kid=\"33\">\n        \n        <div class=\"absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-8 h-8 bg-white border-4 border-[#8da83a] rounded-full z-40 hidden md:flex items-center justify-center\" data-kid=\"34\">\n          <div class=\"w-2 h-2 bg-[#8da83a] rounded-full\" data-kid=\"35\"></div>\n        </div>\n        \n        <div class=\"md:pr-16 order-2 md:order-1\" data-kid=\"36\">\n          <div class=\"group bg-white p-8 rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 ticket-stub-left border border-gray-100\" data-kid=\"37\">\n            <span class=\"font-serif text-8xl absolute top-0 right-4 text-gray-100/60 pointer-events-none group-hover:text-[#8da83a]/10 transition-colors\" data-kid=\"38\">01</span>\n            <div class=\"relative z-10 space-y-4\" data-kid=\"39\">\n              <div class=\"w-16 h-16 rounded-xl bg-[#8da83a]/10 flex items-center justify-center text-[#8da83a]\" data-kid=\"40\">\n                <i class=\"ti ti-award text-3xl\" data-kid=\"41\"></i>\n              </div>\n              <h3 class=\"font-serif text-2xl group-hover:text-[#8da83a] transition-colors\" data-kid=\"42\">Global Humanitarian Award</h3>\n              <p class=\"text-sm font-bold text-[#8da83a] uppercase tracking-widest\" data-kid=\"43\">The UN Foundation</p>\n              <p class=\"text-gray-500 leading-relaxed\" data-kid=\"44\">Recognized for pioneering educational programs for children with disabilities in Southeast Asia, impacting over 10,000 families since 1991.</p>\n              <button class=\"flex items-center gap-2 text-[#1d4e7a] font-bold text-sm hover:gap-4 transition-all group/btn\" data-kid=\"45\">\n                <span data-kid=\"46\">View Details</span>\n                <i class=\"ti ti-arrow-right\" data-kid=\"47\"></i>\n              </button>\n            </div>\n          </div>\n        </div>\n        <div class=\"md:pl-16 order-1 md:order-2\" data-kid=\"48\">\n          <img src=\"https://images.pexels.com/photos/18497739/pexels-photo-18497739.jpeg?auto=format&w=800&q=80&fit=crop\" class=\"rounded-3xl shadow-2xl w-full h-80 object-cover\" alt=\"Award 1\" data-kid=\"49\">\n        </div>\n      </div>\n\n      \n      <div class=\"relative grid md:grid-cols-2 gap-12 items-center\" data-kid=\"50\">\n        \n        <div class=\"absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-8 h-8 bg-white border-4 border-[#8da83a] rounded-full z-40 hidden md:flex items-center justify-center\" data-kid=\"51\">\n          <div class=\"w-2 h-2 bg-[#8da83a] rounded-full\" data-kid=\"52\"></div>\n        </div>\n        \n        <div class=\"md:pr-16\" data-kid=\"53\">\n          <img src=\"https://images.pexels.com/photos/10643462/pexels-photo-10643462.jpeg?auto=format&w=800&q=80&fit=crop\" class=\"rounded-3xl shadow-2xl w-full h-80 object-cover\" alt=\"Award 2\" data-kid=\"54\">\n        </div>\n        <div class=\"md:pl-16\" data-kid=\"55\">\n          <div class=\"group bg-white p-8 rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 ticket-stub-right border border-gray-100\" data-kid=\"56\">\n            <span class=\"font-serif text-8xl absolute top-0 left-4 text-gray-100/60 pointer-events-none group-hover:text-[#8da83a]/10 transition-colors\" data-kid=\"57\">02</span>\n            <div class=\"relative z-10 space-y-4\" data-kid=\"58\">\n              <div class=\"w-16 h-16 rounded-xl bg-[#8da83a]/10 flex items-center justify-center text-[#8da83a]\" data-kid=\"59\">\n                <i class=\"ti ti-medal text-3xl\" data-kid=\"60\"></i>\n              </div>\n              <h3 class=\"font-serif text-2xl group-hover:text-[#8da83a] transition-colors\" data-kid=\"61\">Order of Cambodia</h3>\n              <p class=\"text-sm font-bold text-[#8da83a] uppercase tracking-widest\" data-kid=\"62\">Royal Government of Cambodia</p>\n              <p class=\"text-gray-500 leading-relaxed\" data-kid=\"63\">The highest honor bestowed upon international organizations for exceptional service to the nation’s social development and child welfare.</p>\n              <button class=\"flex items-center gap-2 text-[#1d4e7a] font-bold text-sm hover:gap-4 transition-all group/btn\" data-kid=\"64\">\n                <span data-kid=\"65\">View Details</span>\n                <i class=\"ti ti-arrow-right\" data-kid=\"66\"></i>\n              </button>\n            </div>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"relative grid md:grid-cols-2 gap-12 items-center\" data-kid=\"67\">\n        \n        <div class=\"absolute left-1/2 top-1/2 -translate-x-1/2 -translate-y-1/2 w-8 h-8 bg-white border-4 border-[#8da83a] rounded-full z-40 hidden md:flex items-center justify-center\" data-kid=\"68\">\n          <div class=\"w-2 h-2 bg-[#8da83a] rounded-full\" data-kid=\"69\"></div>\n        </div>\n        \n        <div class=\"md:pr-16 order-2 md:order-1\" data-kid=\"70\">\n          <div class=\"group bg-white p-8 rounded-2xl shadow-xl hover:shadow-2xl transition-all duration-500 ticket-stub-left border border-gray-100\" data-kid=\"71\">\n            <span class=\"font-serif text-8xl absolute top-0 right-4 text-gray-100/60 pointer-events-none group-hover:text-[#8da83a]/10 transition-colors\" data-kid=\"72\">03</span>\n            <div class=\"relative z-10 space-y-4\" data-kid=\"73\">\n              <div class=\"w-16 h-16 rounded-xl bg-[#8da83a]/10 flex items-center justify-center text-[#8da83a]\" data-kid=\"74\">\n                <i class=\"ti ti-certificate text-3xl\" data-kid=\"75\"></i>\n              </div>\n              <h3 class=\"font-serif text-2xl group-hover:text-[#8da83a] transition-colors\" data-kid=\"76\">Innovation in Education</h3>\n              <p class=\"text-sm font-bold text-[#8da83a] uppercase tracking-widest\" data-kid=\"77\">ASEAN Foundation</p>\n              <p class=\"text-gray-500 leading-relaxed\" data-kid=\"78\">For developing accessible braille materials and sign language curricula that have been adopted as national standards.</p>\n              <button class=\"flex items-center gap-2 text-[#1d4e7a] font-bold text-sm hover:gap-4 transition-all group/btn\" data-kid=\"79\">\n                <span data-kid=\"80\">View Details</span>\n                <i class=\"ti ti-arrow-right\" data-kid=\"81\"></i>\n              </button>\n            </div>\n          </div>\n        </div>\n        <div class=\"md:pl-16 order-1 md:order-2\" data-kid=\"82\">\n          <img src=\"https://images.unsplash.com/photo-1743899600614-518350939ccf?auto=format&w=800&q=80&fit=crop\" class=\"rounded-3xl shadow-2xl w-full h-80 object-cover\" alt=\"Award 3\" data-kid=\"83\">\n        </div>\n      </div>\n\n    </div>\n  </section>\n\n  \n  \n  <input type=\"checkbox\" id=\"modal-toggle\" class=\"hidden peer\" data-kid=\"84\">\n  <div class=\"fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/80 backdrop-blur-sm opacity-0 pointer-events-none peer-checked:opacity-100 peer-checked:pointer-events-auto transition-all duration-500\" data-kid=\"85\">\n    <div class=\"bg-white max-w-5xl w-full h-[600px] rounded-3xl overflow-hidden shadow-2xl grid md:grid-cols-[1.2fr_1fr] transform translate-y-8 peer-checked:translate-y-0 transition-all duration-500 delay-100\" data-kid=\"86\">\n      \n      \n      <div class=\"relative h-full bg-[#1d4e7a]\" data-kid=\"87\">\n        <img src=\"https://images.pexels.com/photos/18497739/pexels-photo-18497739.jpeg?auto=format&w=1000&q=90&fit=crop\" class=\"w-full h-full object-cover opacity-60\" alt=\"Detail\" data-kid=\"88\">\n        <div class=\"absolute inset-0 flex items-center justify-center p-12\" data-kid=\"89\">\n          <div class=\"text-center space-y-4\" data-kid=\"90\">\n            <div class=\"w-24 h-24 rounded-2xl bg-white/10 backdrop-blur-md border border-white/20 flex items-center justify-center mx-auto text-white\" data-kid=\"91\">\n               <i class=\"ti ti-award text-5xl\" data-kid=\"92\"></i>\n            </div>\n            <p class=\"text-white text-sm font-bold tracking-widest uppercase opacity-80\" data-kid=\"93\">Timeline Milestone 01</p>\n          </div>\n        </div>\n      </div>\n\n      \n      <div class=\"p-12 flex flex-col justify-between h-full bg-white relative\" data-kid=\"94\">\n        <label for=\"modal-toggle\" class=\"absolute top-6 right-6 w-10 h-10 rounded-full bg-gray-50 flex items-center justify-center cursor-pointer hover:bg-gray-100 transition-colors\" data-kid=\"95\">\n          <i class=\"ti ti-x text-[#1d4e7a] text-xl\" data-kid=\"96\"></i>\n        </label>\n        \n        <div class=\"space-y-8 overflow-y-auto custom-scrollbar pr-4\" data-kid=\"97\">\n          <div class=\"space-y-2\" data-kid=\"98\">\n            <p class=\"text-[#8da83a] text-xs font-bold uppercase tracking-widest\" data-kid=\"99\">Recognition Details</p>\n            <h2 class=\"font-serif text-4xl leading-tight\" data-kid=\"100\">Global Humanitarian Award</h2>\n          </div>\n          \n          <div class=\"space-y-6\" data-kid=\"101\">\n            <div class=\"flex items-start gap-4\" data-kid=\"102\">\n              <div class=\"w-10 h-10 rounded-lg bg-gray-50 flex items-center justify-center text-[#1d4e7a] shrink-0\" data-kid=\"103\">\n                <i class=\"ti ti-building\" data-kid=\"104\"></i>\n              </div>\n              <div data-kid=\"105\">\n                <p class=\"text-[10px] text-gray-400 font-bold uppercase tracking-widest mb-1\" data-kid=\"106\">Awarding Body</p>\n                <p class=\"font-semibold\" data-kid=\"107\">The United Nations Foundation</p>\n              </div>\n            </div>\n            <div class=\"flex items-start gap-4\" data-kid=\"108\">\n              <div class=\"w-10 h-10 rounded-lg bg-gray-50 flex items-center justify-center text-[#1d4e7a] shrink-0\" data-kid=\"109\">\n                <i class=\"ti ti-user-check\" data-kid=\"110\"></i>\n              </div>\n              <div data-kid=\"111\">\n                <p class=\"text-[10px] text-gray-400 font-bold uppercase tracking-widest mb-1\" data-kid=\"112\">Honorable Mention</p>\n                <p class=\"font-semibold\" data-kid=\"113\">Benito Higgins, Regional Director</p>\n              </div>\n            </div>\n          </div>\n\n          <div class=\"prose prose-sm text-gray-600 leading-relaxed\" data-kid=\"114\">\n            <p data-kid=\"115\">For more than three decades, Krousar Thmey has been at the forefront of inclusive education. This recognition from the UN Foundation underscores the profound impact of integrating disabled children into the formal schooling system.</p>\n            <p data-kid=\"116\">The award celebrates the development of the national sign language dictionary and the training of over 500 specialized educators.</p>\n          </div>\n        </div>\n\n        <div class=\"pt-8 border-t border-gray-100\" data-kid=\"117\">\n          <a href=\"#\" class=\"inline-flex items-center justify-center gap-3 bg-[#1d4e7a] text-white px-8 py-4 rounded-xl font-bold text-sm hover:bg-[#2d6fa3] transition-all w-full shadow-lg hover:shadow-xl shadow-[#1d4e7a]/20\" data-kid=\"118\">\n            <span data-kid=\"119\">Read Official Press Release</span>\n            <i class=\"ti ti-external-link\" data-kid=\"120\"></i>\n          </a>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"fixed bottom-8 left-1/2 -translate-x-1/2 z-50\" data-kid=\"121\">\n    <label for=\"modal-toggle\" class=\"bg-[#8da83a] text-white px-6 py-3 rounded-full shadow-2xl font-bold text-sm cursor-pointer hover:bg-[#7a9332] transition-all flex items-center gap-2\" data-kid=\"122\">\n      <i class=\"ti ti-zoom-in\" data-kid=\"123\"></i>\n      <span data-kid=\"124\">Preview Modal View</span>\n    </label>\n  </div>\n\n</div>",
