    "var_41942f5f84f5": {
      "type": "variant",
      "label": "Visitor: Incandescent Spotlight",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 7380,
        "y": 0,
        "w": 1280,
        "h": 800
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700;800&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  .font-serif {\n    font-family: 'Playfair Display', serif;\n  }\n  .font-sans {\n    font-family: 'Inter', sans-serif;\n  }\n\n  /* Incandescent Spotlight Glow */\n  .spotlight-stage::before {\n    content: '';\n    position: absolute;\n    inset: -50px;\n    background: radial-gradient(circle, rgba(141, 168, 58, 0.25) 0%, rgba(45, 111, 163, 0.05) 60%, transparent 100%);\n    border-radius: 50%;\n    z-index: 0;\n    animation: glow-pulse 4s ease-in-out infinite;\n  }\n\n  @keyframes glow-pulse {\n    0%, 100% { transform: scale(1); opacity: 0.6; }\n    50% { transform: scale(1.1); opacity: 0.9; }\n  }\n\n  /* Sticky Scroll Highlights */\n  .award-list-item {\n    transition: all 0.5s ease;\n    border-left: 2px solid transparent;\n  }\n  .award-list-item.active {\n    border-left-color: #8da83a;\n    padding-left: 2rem;\n    opacity: 1;\n  }\n  .award-list-item:not(.active) {\n    opacity: 0.4;\n  }\n\n  /* Side Drawer */\n  #sideDrawer {\n    transform: translateX(100%);\n    transition: transform 0.4s cubic-bezier(0.4, 0, 0.2, 1);\n  }\n  #sideDrawer.open {\n    transform: translateX(0);\n  }\n  #drawerOverlay {\n    opacity: 0;\n    pointer-events: none;\n    transition: opacity 0.4s ease;\n  }\n  #drawerOverlay.open {\n    opacity: 1;\n    pointer-events: auto;\n  }\n</style>\n\n<div class=\"font-sans text-[#1a3c6e] bg-[#f8f9fc] selection:bg-[#8da83a]/20\" data-kid=\"1\">\n    \n    <section class=\"relative h-screen w-full flex items-center justify-center overflow-hidden\" data-kid=\"2\">\n        <video src=\"https://videos.pexels.com/video-files/5733051/5733051-hd_1920_1080_25fps.mp4\" poster=\"https://images.pexels.com/videos/5733051/asian-children-blind-man-s-buff-child-playing-childhood-5733051.jpeg?auto=compress&cs=tinysrgb&fit=crop&h=1080&w=1920\" autoplay muted loop playsinline preload=\"metadata\" class=\"absolute inset-0 w-full h-full object-cover\" data-kid=\"3\">\n        </video>\n        <div class=\"absolute inset-0 bg-[#1a3c6e]/75 backdrop-blur-[2px]\" data-kid=\"4\"></div>\n        \n        <div class=\"relative z-10 text-center px-6 max-w-5xl\" data-kid=\"5\">\n            <h1 class=\"text-7xl md:text-9xl font-serif text-white mb-8 tracking-tight leading-none\" data-kid=\"6\">\n                A History of <span class=\"text-[#8da83a]\" data-kid=\"7\">Recognition</span>\n            </h1>\n            <p class=\"text-white/70 text-xl md:text-2xl max-w-2xl mx-auto font-light leading-relaxed\" data-kid=\"8\">\n                Celebrating three decades of humanitarian impact and sustainable growth in Cambodia.\n            </p>\n        </div>\n\n        <div class=\"absolute bottom-12 left-1/2 -translate-x-1/2 z-10 animate-bounce cursor-pointer\" onclick=\"document.getElementById('main-content').scrollIntoView({behavior: 'smooth'})\" data-kid=\"9\">\n            <i class=\"ti ti-arrow-down text-[#8da83a] text-4xl\" data-kid=\"10\"></i>\n        </div>\n    </section>\n\n    \n    <div class=\"sticky top-0 z-40 bg-white/80 backdrop-blur-md border-b border-[#1a3c6e]/5 py-4 px-8\" data-kid=\"11\">\n        <nav class=\"flex items-center gap-3 text-sm font-medium\" data-kid=\"12\">\n            <a href=\"#\" class=\"text-[#1a3c6e]/40 hover:text-[#1a3c6e] transition-colors\" data-kid=\"13\">Home</a>\n            <i class=\"ti ti-chevron-right text-[#1a3c6e]/20\" data-kid=\"14\"></i>\n            <span class=\"text-[#1a3c6e]\" data-kid=\"15\">Awards & Recognitions</span>\n        </nav>\n    </div>\n\n    \n    <main id=\"main-content\" class=\"max-w-7xl mx-auto px-6 flex flex-col md:flex-row gap-20 py-32 min-h-screen\" data-kid=\"16\">\n        \n        \n        <div class=\"hidden md:flex w-[45%] sticky top-32 h-[calc(100vh-160px)] items-center justify-center\" data-kid=\"17\">\n            <div class=\"spotlight-stage relative w-full aspect-square flex items-center justify-center\" data-kid=\"18\">\n                <div id=\"stageContent\" class=\"relative z-10 w-80 h-80 rounded-3xl bg-white shadow-[0_20px_50px_rgba(26,60,110,0.15)] overflow-hidden transition-all duration-700 transform\" data-kid=\"19\">\n                    <img id=\"stageImage\" src=\"https://images.pexels.com/photos/32615470/pexels-photo-32615470.jpeg?auto=format&w=800&q=80&fit=crop\" alt=\"Featured Award\" class=\"w-full h-full object-cover opacity-0 transition-opacity duration-500\" decoding=\"async\" loading=\"lazy\" data-kid=\"20\">\n                    <div id=\"stageIcon\" class=\"absolute inset-0 flex items-center justify-center bg-gradient-to-br from-[#2d6fa3] to-[#1a3c6e] text-white opacity-0 transition-opacity duration-500\" data-kid=\"21\">\n                        <span class=\"text-9xl\" data-kid=\"22\">🏆</span>\n                    </div>\n                </div>\n            </div>\n        </div>\n\n        \n        <div class=\"w-full md:w-[55%] space-y-48 pb-[40vh] pt-[10vh]\" data-kid=\"23\">\n            \n            \n            <article class=\"award-list-item pl-8 group\" data-image=\"https://images.pexels.com/photos/32615470/pexels-photo-32615470.jpeg?auto=format&w=800&q=80&fit=crop\" data-title=\"Global Humanitarian Award\" data-org=\"International Peace Bureau\" data-recipient=\"Krousar Thmey Foundation\" data-desc=\"Recognized for outstanding dedication to education and social integration for children with disabilities in Cambodia. This award honors the long-term commitment to human rights and inclusive education since 1991.\" data-kid=\"24\">\n                <span class=\"text-[#8da83a] text-sm font-bold tracking-[0.2em] uppercase mb-4 block\" data-kid=\"25\">2023 • Foundation Excellence</span>\n                <h2 class=\"text-4xl md:text-5xl font-serif mb-6 leading-tight group-hover:text-[#2d6fa3] transition-colors cursor-pointer\" onclick=\"openDrawer(this.closest('article'))\" data-kid=\"26\">\n                    Global Humanitarian Award\n                </h2>\n                <p class=\"text-[#2d6fa3] text-lg font-semibold mb-6\" data-kid=\"27\">International Peace Bureau</p>\n                <button onclick=\"openDrawer(this.closest('article'))\" class=\"inline-flex items-center gap-3 px-6 py-3 border border-[#1a3c6e]/20 rounded-full text-sm font-bold hover:bg-[#1a3c6e] hover:text-white transition-all duration-300\" data-kid=\"28\">\n                    VIEW DETAILS <i class=\"ti ti-arrow-narrow-right\" data-kid=\"29\"></i>\n                </button>\n            </article>\n\n            \n            <article class=\"award-list-item pl-8 group\" data-icon=\"🎖️\" data-title=\"Regional Integration Prize\" data-org=\"ASEAN Social Council\" data-recipient=\"Benoit Duchâteau-Arminjon\" data-desc=\"Awarded for pioneering work in establishing the first unified sign language and Braille system for the Khmer language, enabling thousands of children to access formal education.\" data-kid=\"30\">\n                <span class=\"text-[#8da83a] text-sm font-bold tracking-[0.2em] uppercase mb-4 block\" data-kid=\"31\">2021 • Innovation in Inclusion</span>\n                <h2 class=\"text-4xl md:text-5xl font-serif mb-6 leading-tight group-hover:text-[#2d6fa3] transition-colors cursor-pointer\" onclick=\"openDrawer(this.closest('article'))\" data-kid=\"32\">\n                    Regional Integration Prize\n                </h2>\n                <p class=\"text-[#2d6fa3] text-lg font-semibold mb-6\" data-kid=\"33\">ASEAN Social Council</p>\n                <button onclick=\"openDrawer(this.closest('article'))\" class=\"inline-flex items-center gap-3 px-6 py-3 border border-[#1a3c6e]/20 rounded-full text-sm font-bold hover:bg-[#1a3c6e] hover:text-white transition-all duration-300\" data-kid=\"34\">\n                    VIEW DETAILS <i class=\"ti ti-arrow-narrow-right\" data-kid=\"35\"></i>\n                </button>\n            </article>\n\n            \n            <article class=\"award-list-item pl-8 group\" data-icon=\"🌟\" data-title=\"Sustainability Impact Award\" data-org=\"Global Giving Initiative\" data-recipient=\"The Community Outreach Team\" data-desc=\"Celebrating three decades of sustainable community-led development. Krousar Thmey was lauded for its successful transition of schools to the state system, ensuring long-term national impact.\" data-kid=\"36\">\n                <span class=\"text-[#8da83a] text-sm font-bold tracking-[0.2em] uppercase mb-4 block\" data-kid=\"37\">2019 • Social Sustainability</span>\n                <h2 class=\"text-4xl md:text-5xl font-serif mb-6 leading-tight group-hover:text-[#2d6fa3] transition-colors cursor-pointer\" onclick=\"openDrawer(this.closest('article'))\" data-kid=\"38\">\n                    Sustainability Impact Award\n                </h2>\n                <p class=\"text-[#2d6fa3] text-lg font-semibold mb-6\" data-kid=\"39\">Global Giving Initiative</p>\n                <button onclick=\"openDrawer(this.closest('article'))\" class=\"inline-flex items-center gap-3 px-6 py-3 border border-[#1a3c6e]/20 rounded-full text-sm font-bold hover:bg-[#1a3c6e] hover:text-white transition-all duration-300\" data-kid=\"40\">\n                    VIEW DETAILS <i class=\"ti ti-arrow-narrow-right\" data-kid=\"41\"></i>\n                </button>\n            </article>\n\n        </div>\n    </main>\n\n    \n    <div id=\"drawerOverlay\" class=\"fixed inset-0 z-[60] bg-[#1a3c6e]/40 backdrop-blur-sm\" onclick=\"closeDrawer()\" data-kid=\"42\"></div>\n\n    \n    <aside id=\"sideDrawer\" class=\"fixed top-0 right-0 z-[70] h-full w-full max-w-xl bg-white shadow-[-20px_0_50px_rgba(0,0,0,0.1)] flex flex-col\" data-kid=\"43\">\n        <div class=\"p-8 flex justify-between items-center border-b border-gray-100\" data-kid=\"44\">\n            <h3 class=\"font-serif text-2xl\" data-kid=\"45\">Award Detail</h3>\n            <button onclick=\"closeDrawer()\" class=\"w-10 h-10 flex items-center justify-center rounded-full hover:bg-gray-100 transition-colors\" data-kid=\"46\">\n                <i class=\"ti ti-x text-2xl\" data-kid=\"47\"></i>\n            </button>\n        </div>\n        \n        <div class=\"flex-1 overflow-y-auto p-12\" data-kid=\"48\">\n            <div id=\"drawerImageContainer\" class=\"w-full aspect-video rounded-2xl overflow-hidden mb-12 bg-gray-50\" data-kid=\"49\">\n                \n            </div>\n            \n            <div class=\"space-y-8\" data-kid=\"50\">\n                <div data-kid=\"51\">\n                    <span id=\"drawerBadge\" class=\"text-[#8da83a] text-sm font-bold tracking-widest uppercase mb-2 block\" data-kid=\"52\"></span>\n                    <h2 id=\"drawerTitle\" class=\"text-4xl font-serif leading-tight mb-4\" data-kid=\"53\"></h2>\n                </div>\n                \n                <div class=\"grid grid-cols-2 gap-8\" data-kid=\"54\">\n                    <div data-kid=\"55\">\n                        <p class=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2\" data-kid=\"56\">Organization</p>\n                        <p id=\"drawerOrg\" class=\"text-[#1a3c6e] font-semibold\" data-kid=\"57\"></p>\n                    </div>\n                    <div data-kid=\"58\">\n                        <p class=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-2\" data-kid=\"59\">Recipient</p>\n                        <p id=\"drawerRecipient\" class=\"text-[#1a3c6e] font-semibold\" data-kid=\"60\"></p>\n                    </div>\n                </div>\n\n                <div class=\"pt-8 border-t border-gray-100\" data-kid=\"61\">\n                    <p class=\"text-[10px] font-bold text-gray-400 uppercase tracking-widest mb-4\" data-kid=\"62\">Description</p>\n                    <p id=\"drawerDesc\" class=\"text-gray-600 leading-relaxed text-lg\" data-kid=\"63\"></p>\n                </div>\n\n                <div class=\"pt-12\" data-kid=\"64\">\n                    <a href=\"#\" class=\"w-full inline-flex items-center justify-center gap-3 px-8 py-4 bg-[#1a3c6e] text-white rounded-xl font-bold hover:bg-[#2d6fa3] transition-all transform hover:-translate-y-1\" data-kid=\"65\">\n                        VIEW OFFICIAL ANNOUNCEMENT <i class=\"ti ti-external-link\" data-kid=\"66\"></i>\n                    </a>\n                </div>\n            </div>\n        </div>\n    </aside>\n\n    \n    <section class=\"bg-[#1a3c6e] py-32 px-6 text-center\" data-kid=\"67\">\n        <div class=\"max-w-4xl mx-auto\" data-kid=\"68\">\n            <h2 class=\"text-4xl md:text-5xl font-serif text-white mb-8\" data-kid=\"69\">Recognition is just a milestone. The real reward is their <span class=\"text-[#8da83a]\" data-kid=\"70\">future</span>.</h2>\n            <div class=\"flex flex-col md:flex-row items-center justify-center gap-6\" data-kid=\"71\">\n                <a href=\"#\" class=\"px-10 py-4 bg-[#8da83a] text-white rounded-full font-bold hover:bg-[#7a9432] transition-all transform hover:scale-105\" data-kid=\"72\">SUPPORT OUR MISSION</a>\n                <a href=\"#\" class=\"px-10 py-4 border border-white/20 text-white rounded-full font-bold hover:bg-white/10 transition-all\" data-kid=\"73\">READ IMPACT REPORTS</a>\n            </div>\n        </div>\n    </section>\n</div>\n\n<script data-kid=\"74\">\n    // Sticky Scroll Logic\n    const awardItems = document.querySelectorAll('.award-list-item');\n    const stageImage = document.getElementById('stageImage');\n    const stageIcon = document.getElementById('stageIcon');\n    const stageContent = document.getElementById('stageContent');\n\n    const observerOptions = {\n        root: null,\n        rootMargin: '-40% 0% -40% 0%',\n        threshold: 0\n    };\n\n    const observer = new IntersectionObserver((entries) => {\n        entries.forEach(entry => {\n            if (entry.isIntersecting) {\n                // Remove active from others\n                awardItems.forEach(item => item.classList.remove('active'));\n                entry.target.classList.add('active');\n\n                // Update Stage\n                const img = entry.target.dataset.image;\n                const icon = entry.target.dataset.icon;\n                \n                stageContent.style.transform = 'scale(0.95)';\n                setTimeout(() => {\n                    if (img) {\n                        stageImage.src = img;\n                        stageImage.classList.replace('opacity-0', 'opacity-100');\n                        stageIcon.classList.replace('opacity-100', 'opacity-0');\n                    } else if (icon) {\n                        stageIcon.querySelector('span').textContent = icon;\n                        stageIcon.classList.replace('opacity-0', 'opacity-100');\n                        stageImage.classList.replace('opacity-100', 'opacity-0');\n                    }\n                    stageContent.style.transform = 'scale(1)';\n                }, 200);\n            }\n        });\n    }, observerOptions);\n\n    awardItems.forEach(item => observer.observe(item));\n\n    // Drawer Logic\n    function openDrawer(article) {\n        const data = article.dataset;\n        document.getElementById('drawerTitle').textContent = data.title;\n        document.getElementById('drawerOrg').textContent = data.org;\n        document.getElementById('drawerRecipient').textContent = data.recipient;\n        document.getElementById('drawerDesc').textContent = data.desc;\n        document.getElementById('drawerBadge').textContent = article.querySelector('span').textContent;\n\n        const container = document.getElementById('drawerImageContainer');\n        if (data.image) {\n            container.innerHTML = `<img src=\"${data.image}\" class=\"w-full h-full object-cover\">`;\n        } else {\n            container.innerHTML = `<div class=\"w-full h-full flex items-center justify-center bg-[#1a3c6e] text-white text-7xl\">${data.icon}</div>`;\n        }\n\n        document.getElementById('sideDrawer').classList.add('open');\n        document.getElementById('drawerOverlay').classList.add('open');\n        document.body.style.overflow = 'hidden';\n    }\n\n    function closeDrawer() {\n        document.getElementById('sideDrawer').classList.remove('open');\n        document.getElementById('drawerOverlay').classList.remove('open');\n        document.body.style.overflow = '';\n    }\n</script>",
      "comments": [],
      "created": "2026-07-08T11:54:23.956561+00:00",
      "modified": "2026-07-08T11:54:56.750715+00:00",
