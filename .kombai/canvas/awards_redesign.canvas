    },
    "var_282687fc9277": {
      "type": "variant",
      "label": "Admin: Integrated Create Form",
      "parentId": null,
      "themeId": null,
      "rect": {
        "x": 8760,
        "y": 0,
        "w": 1280,
        "h": 800
      },
      "html": "<style data-kid=\"0\">\n  @import url('https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=Playfair+Display:wght@700&display=swap');\n  @import url('https://cdn.jsdelivr.net/npm/@tabler/icons-webfont/tabler-icons.min.css');\n\n  :root {\n    --kt-blue: #2d6fa3;\n    --kt-blue-dark: #1a3c6e;\n    --kt-olive: #8da83a;\n    --kt-bg: #f8f9fc;\n    --kt-border: #e2e8f0;\n  }\n\n  body {\n    background-color: var(--kt-bg);\n    font-family: 'Inter', sans-serif;\n    color: #334155;\n    margin: 0;\n    padding: 2rem;\n  }\n\n  .font-serif {\n    font-family: 'Playfair Display', serif;\n  }\n\n  /* Custom focus ring for brand color */\n  .focus-brand:focus {\n    outline: none;\n    box-shadow: 0 0 0 3px rgba(45, 111, 163, 0.1);\n    border-color: var(--kt-blue);\n  }\n\n  /* Upload Area Styling */\n  .upload-zone {\n    border: 2px dashed var(--kt-border);\n    transition: all 0.3s ease;\n  }\n\n  .upload-zone:hover {\n    border-color: var(--kt-blue);\n    background-color: rgba(45, 111, 163, 0.02);\n  }\n\n  .btn-discard {\n    transition: all 0.2s;\n  }\n  .btn-discard:hover {\n    background-color: #f1f5f9;\n  }\n\n  .btn-publish {\n    background: var(--kt-blue);\n    transition: all 0.2s;\n  }\n  .btn-publish:hover {\n    background: var(--kt-blue-dark);\n    transform: translateY(-1px);\n    box-shadow: 0 4px 12px rgba(26, 60, 110, 0.2);\n  }\n</style>\n\n<div class=\"max-w-6xl mx-auto\" data-kid=\"1\">\n  \n  <div class=\"flex items-center justify-between mb-8\" data-kid=\"2\">\n    <div data-kid=\"3\">\n      <h1 class=\"text-3xl font-serif text-[var(--kt-blue-dark)]\" data-kid=\"4\">Manage Awards</h1>\n      <p class=\"text-slate-500 text-sm mt-1\" data-kid=\"5\">Add or update recognition entries for the Krousar Thmey gallery.</p>\n    </div>\n    <div class=\"flex gap-4\" data-kid=\"6\">\n      <div class=\"bg-white border border-[var(--kt-border)] px-4 py-2 rounded-xl flex items-center gap-3\" data-kid=\"7\">\n        <div class=\"w-8 h-8 rounded-lg bg-[var(--kt-olive)]/10 flex items-center justify-center text-[var(--kt-olive)]\" data-kid=\"8\">\n          <i class=\"ti ti-trophy text-lg\" data-kid=\"9\"></i>\n        </div>\n        <div data-kid=\"10\">\n          <p class=\"text-[10px] uppercase tracking-wider font-bold text-slate-400 leading-none\" data-kid=\"11\">Total</p>\n          <p class=\"text-lg font-bold text-slate-700 leading-none mt-1\" data-kid=\"12\">24</p>\n        </div>\n      </div>\n    </div>\n  </div>\n\n  \n  <div class=\"bg-white rounded-2xl border border-[var(--kt-border)] shadow-sm overflow-hidden mb-12\" data-kid=\"13\">\n    \n    <div class=\"px-8 py-5 border-b border-[var(--kt-border)] bg-slate-50/50 flex items-center justify-between\" data-kid=\"14\">\n      <div class=\"flex items-center gap-3\" data-kid=\"15\">\n        <div class=\"w-10 h-10 rounded-xl bg-[var(--kt-blue)] flex items-center justify-center text-white shadow-lg shadow-blue-900/10\" data-kid=\"16\">\n          <i class=\"ti ti-plus text-xl\" data-kid=\"17\"></i>\n        </div>\n        <h2 class=\"text-sm font-bold uppercase tracking-widest text-slate-600\" data-kid=\"18\">Create New Entry</h2>\n      </div>\n      <div class=\"flex items-center gap-2\" data-kid=\"19\">\n         <span class=\"flex h-2 w-2 rounded-full bg-[var(--kt-olive)]\" data-kid=\"20\"></span>\n         <span class=\"text-[10px] font-bold text-slate-400 uppercase tracking-tighter\" data-kid=\"21\">Drafting Mode</span>\n      </div>\n    </div>\n\n    \n    <div class=\"p-8\" data-kid=\"22\">\n      <div class=\"grid grid-cols-1 lg:grid-cols-3 gap-10\" data-kid=\"23\">\n        \n        \n        <div class=\"lg:col-span-2 space-y-6\" data-kid=\"24\">\n          <div class=\"grid grid-cols-1 md:grid-cols-2 gap-6\" data-kid=\"25\">\n            \n            <div class=\"space-y-2\" data-kid=\"26\">\n              <label class=\"text-[10px] font-bold text-slate-500 uppercase tracking-widest flex items-center gap-1\" data-kid=\"27\">\n                Award Title <span class=\"text-red-500\" data-kid=\"28\">*</span>\n              </label>\n              <input type=\"text\" placeholder=\"e.g. Humanitarian Excellence 2024\" class=\"w-full px-4 py-3 bg-slate-50 border border-[var(--kt-border)] rounded-xl text-sm focus-brand transition-all placeholder:text-slate-300\" data-kid=\"29\">\n            </div>\n\n            \n            <div class=\"space-y-2\" data-kid=\"30\">\n              <label class=\"text-[10px] font-bold text-slate-500 uppercase tracking-widest flex items-center gap-1\" data-kid=\"31\">\n                Organization <span class=\"text-red-500\" data-kid=\"32\">*</span>\n              </label>\n              <input type=\"text\" placeholder=\"e.g. UNESCO\" class=\"w-full px-4 py-3 bg-slate-50 border border-[var(--kt-border)] rounded-xl text-sm focus-brand transition-all placeholder:text-slate-300\" data-kid=\"33\">\n            </div>\n\n            \n            <div class=\"space-y-2\" data-kid=\"34\">\n              <label class=\"text-[10px] font-bold text-slate-500 uppercase tracking-widest\" data-kid=\"35\">\n                Recipient\n              </label>\n              <input type=\"text\" placeholder=\"Person name (if specific)\" class=\"w-full px-4 py-3 bg-slate-50 border border-[var(--kt-border)] rounded-xl text-sm focus-brand transition-all placeholder:text-slate-300\" data-kid=\"36\">\n            </div>\n\n            \n            <div class=\"space-y-2\" data-kid=\"37\">\n              <label class=\"text-[10px] font-bold text-slate-500 uppercase tracking-widest\" data-kid=\"38\">\n                Link Type\n              </label>\n              <div class=\"relative\" data-kid=\"39\">\n                <select class=\"w-full px-4 py-3 bg-slate-50 border border-[var(--kt-border)] rounded-xl text-sm focus-brand transition-all appearance-none cursor-pointer\" data-kid=\"40\">\n                  <option data-kid=\"41\">None</option>\n                  <option data-kid=\"42\">Website</option>\n                  <option data-kid=\"43\">Article</option>\n                  <option data-kid=\"44\">Video</option>\n                </select>\n                <i class=\"ti ti-chevron-down absolute right-4 top-1/2 -translate-y-1/2 text-slate-400 pointer-events-none\" data-kid=\"45\"></i>\n              </div>\n            </div>\n          </div>\n\n          \n          <div class=\"space-y-2\" data-kid=\"46\">\n            <label class=\"text-[10px] font-bold text-slate-500 uppercase tracking-widest\" data-kid=\"47\">\n              Summary Description\n            </label>\n            <textarea placeholder=\"Briefly describe the significance of this award...\" rows=\"4\" class=\"w-full px-4 py-3 bg-slate-50 border border-[var(--kt-border)] rounded-xl text-sm focus-brand transition-all placeholder:text-slate-300 resize-none\" data-kid=\"48\"></textarea>\n          </div>\n        </div>\n\n        \n        <div class=\"space-y-2\" data-kid=\"49\">\n          <label class=\"text-[10px] font-bold text-slate-500 uppercase tracking-widest\" data-kid=\"50\">\n            Featured Media\n          </label>\n          <div class=\"upload-zone h-[calc(100%-1.5rem)] rounded-2xl flex flex-col items-center justify-center text-center p-6 cursor-pointer group\" data-kid=\"51\">\n            <div class=\"w-16 h-16 rounded-full bg-slate-100 flex items-center justify-center text-slate-400 mb-4 group-hover:bg-[var(--kt-blue)] group-hover:text-white transition-all duration-300\" data-kid=\"52\">\n              <i class=\"ti ti-upload text-2xl\" data-kid=\"53\"></i>\n            </div>\n            <p class=\"text-sm font-semibold text-slate-700\" data-kid=\"54\">Drop your file here</p>\n            <p class=\"text-[11px] text-slate-400 mt-1\" data-kid=\"55\">JPG, PNG OR WEBP UP TO 2MB</p>\n            <div class=\"mt-6\" data-kid=\"56\">\n              <button class=\"text-xs font-bold text-[var(--kt-blue)] hover:underline\" data-kid=\"57\">Or browse files</button>\n            </div>\n          </div>\n        </div>\n\n      </div>\n    </div>\n\n    \n    <div class=\"px-8 py-6 border-t border-[var(--kt-border)] bg-slate-50/30 flex items-center justify-end gap-4\" data-kid=\"58\">\n      <button class=\"btn-discard px-6 py-2.5 rounded-xl text-sm font-bold text-slate-500\" data-kid=\"59\">\n        Discard\n      </button>\n      <button class=\"btn-publish px-8 py-2.5 rounded-xl text-sm font-bold text-white shadow-lg shadow-blue-900/20 flex items-center gap-2\" data-kid=\"60\">\n        <i class=\"ti ti-circle-check text-lg\" data-kid=\"61\"></i>\n        Publish Award Entry\n      </button>\n    </div>\n  </div>\n\n  \n  <div class=\"opacity-40 pointer-events-none grayscale\" data-kid=\"62\">\n    <div class=\"flex items-center justify-between mb-4\" data-kid=\"63\">\n      <h3 class=\"text-sm font-bold uppercase tracking-widest text-slate-400\" data-kid=\"64\">Recently Added</h3>\n    </div>\n    <div class=\"bg-white rounded-2xl border border-[var(--kt-border)] p-4 flex items-center gap-6\" data-kid=\"65\">\n       <div class=\"w-16 h-16 bg-slate-100 rounded-xl\" data-kid=\"66\"></div>\n       <div class=\"flex-1\" data-kid=\"67\">\n         <div class=\"h-4 w-48 bg-slate-100 rounded\" data-kid=\"68\"></div>\n         <div class=\"h-3 w-32 bg-slate-50 rounded mt-2\" data-kid=\"69\"></div>\n       </div>\n    </div>\n  </div>\n\n</div>",
